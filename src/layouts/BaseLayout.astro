---
import '../styles/global.css';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { getSchemaGraph } from '../lib/schema';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  schemaPage?: 'home' | 'faqs' | 'contact' | 'service' | 'area' | 'project' | 'blog' | 'about' | 'other';
  schemaFaqs?: { question: string; answer: string }[];
  schemaBreadcrumbs?: { name: string; url: string }[];
  schemaServiceName?: string;
  schemaServiceDescription?: string;
  schemaAreaName?: string;
  schemaArticleTitle?: string;
  schemaArticlePublishDate?: string;
  schemaArticleAuthor?: string;
  schemaArticleImage?: string;
  schemaProjectName?: string;
  schemaProjectDescription?: string;
  schemaProjectImage?: string;
  schemaProjectYear?: number;
  schemaProjectCity?: string;
  schemaProjectServices?: string[];
  whatsappMessage?: string;
  noindex?: boolean;
  ogType?: string;
  preloadImage?: { href: string; imagesrcset?: string; imagesizes?: string };
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage = '/img/logo-full.png',
  schemaPage = 'other',
  schemaFaqs,
  schemaBreadcrumbs,
  schemaServiceName,
  schemaServiceDescription,
  schemaAreaName,
  schemaArticleTitle,
  schemaArticlePublishDate,
  schemaArticleAuthor,
  schemaArticleImage,
  schemaProjectName,
  schemaProjectDescription,
  schemaProjectImage,
  schemaProjectYear,
  schemaProjectCity,
  schemaProjectServices,
  whatsappMessage,
  noindex = false,
  ogType = 'website',
  preloadImage,
} = Astro.props;

// Titles are authored complete (brand included where it fits, ≤60 chars).
// Do not auto-append the brand here, or pages whose title already contains
// it render the brand twice.
const fullTitle = title;

// Open Graph / Twitter need absolute image URLs. Authored ogImage values are
// site-relative (e.g. /img/...), so resolve them against the configured site.
const ogImageAbsolute = new URL(ogImage, Astro.site ?? canonicalUrl).href;

const jsonLd = getSchemaGraph({
  page: schemaPage,
  canonicalUrl,
  breadcrumbs: schemaBreadcrumbs,
  faqs: schemaFaqs,
  serviceName: schemaServiceName,
  serviceDescription: schemaServiceDescription,
  areaName: schemaAreaName,
  articleTitle: schemaArticleTitle,
  articlePublishDate: schemaArticlePublishDate,
  articleAuthor: schemaArticleAuthor,
  articleImage: schemaArticleImage,
  projectName: schemaProjectName,
  projectDescription: schemaProjectDescription,
  projectImage: schemaProjectImage,
  projectYear: schemaProjectYear,
  projectCity: schemaProjectCity,
  projectServices: schemaProjectServices,
});
---

<!doctype html>
<html lang="en" class="h-full w-full">
  <head>
    <!-- Google Tag Manager (deferred off the critical path) -->
    <script>
      window.dataLayer = window.dataLayer || [];
      // GTM (~270KB) was loading on the critical path and inflating mobile TBT/LCP.
      // Load it on the first user interaction, or after idle as a fallback so
      // non-interacting sessions are still tracked. dataLayer is available
      // immediately, so inline dataLayer.push() handlers keep working.
      (function () {
        var loaded = false;
        var events = ['scroll', 'mousedown', 'touchstart', 'keydown'];
        function cleanup() {
          events.forEach(function (e) { window.removeEventListener(e, loadGTM); });
          window.removeEventListener('load', onLoad);
        }
        function loadGTM() {
          if (loaded) return;
          loaded = true;
          cleanup();
          window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
          var j = document.createElement('script');
          j.async = true;
          j.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-NKXT65VJ';
          document.head.appendChild(j);
        }
        // Load on first interaction; otherwise fall back to shortly after the
        // window load event (which fires after LCP), so GTM's ~270KB never
        // competes for the main thread during the LCP window.
        function onLoad() { setTimeout(loadGTM, 2000); }
        events.forEach(function (e) { window.addEventListener(e, loadGTM, { once: true, passive: true }); });
        window.addEventListener('load', onLoad);
      })();
    </script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Sun Synergy Contracts" />
    <meta property="og:locale" content="en_MY" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/img/favicon/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/img/favicon/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/img/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/img/favicon/site.webmanifest" />

    <!-- Fonts (loaded async so they don't block first render; display=swap
         shows fallback text immediately and swaps when the webfont arrives) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;700;900&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;700;900&display=swap" />
    </noscript>

    {preloadImage && (
      <link
        rel="preload"
        as="image"
        href={preloadImage.href}
        imagesrcset={preloadImage.imagesrcset}
        imagesizes={preloadImage.imagesizes}
        fetchpriority="high"
      />
    )}

    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.1/dist/cdn.min.js"></script>

    <!-- Schema.org JSON-LD graph -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body x-data="{ isCurrentScrollAtTop: true, isNavigationFlyoutOpen: false, isGalleryModalOpen: false, idGallery: '' }" class="overflow-x-hidden bg-black">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NKXT65VJ"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <slot name="header">
      <header class="fixed left-0 top-0 z-50 w-full transition-[background-color] duration-700 border-[#333]" :class="isCurrentScrollAtTop ? 'backdrop-blur-[0]' : 'bg-black/60 border-b backdrop-blur-xl'" @scroll.window="isCurrentScrollAtTop = (window.pageYOffset < 200)">
        <div class="flex min-h-[4rem] w-full max-w-screen-xl items-center justify-between px-4 text-[#FAFAFA] sm:px-8 relative mx-auto flex-wrap transition-[height]">
          <a aria-label="logo" class="flex h-20 md:h-16 gap-2 w-auto flex-none items-center" href="/">
            <img src="/img/logo-full.png" alt="Sun Synergy Contracts Logo" width="809" height="460" class="h-16 md:h-10 w-auto block md:hidden" />
            <img src="/img/logo.png" alt="Sun Synergy Contracts Logo" width="768" height="460" class="h-16 md:h-10 w-auto hidden md:block" />
            <p class="text-[#FAFAFA] text-lg font-bold hidden md:block">SUN SYNERGY CONTRACTS</p>
          </a>

          <div class="flex h-20 md:h-16 w-auto flex-none items-center justify-end gap-4">
            <a
              href="/contact/"
              class="block mx-auto rounded-md bg-[#FAFAFA] cursor-pointer border-gray-300 border-[0.2px] px-3.5 py-2.5 text-sm font-bold text-[#333] ring-1 ring-inset ring-gray-300 shadow-md hover:ring-[#333] hover:bg-[#333] hover:text-[#FAFAFA] transition-all duration-150 ease-linear"
              onclick="window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'nav_cta_click',cta_label:'Speak with us'});"
            >Speak with us</a>
            <div class="relative">
              <button @click="isNavigationFlyoutOpen = !isNavigationFlyoutOpen" type="button" aria-label="Open navigation menu" class="text-[#FAFAFA] cursor-pointer" :aria-expanded="isNavigationFlyoutOpen">
                <svg x-show="!isNavigationFlyoutOpen" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 5.25h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5" />
                </svg>
                <svg x-cloak x-show="isNavigationFlyoutOpen" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
              </button>
              <div x-cloak x-show="isNavigationFlyoutOpen" @click.outside="isNavigationFlyoutOpen = false" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 translate-y-1" x-transition:enter-end="opacity-100 translate-y-0" x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100 translate-y-0" x-transition:leave-end="opacity-0 translate-y-1" class="absolute z-10 mt-5 flex w-screen max-w-min -translate-x-[80%] px-4">
                <div class="w-56 shrink rounded-xl bg-[#FAFAFA] text-sm font-semibold leading-6 text-gray-900 shadow-lg ring-1 ring-gray-900/5">
                  <a href="/" class="block px-4 py-3 hover:text-[#FAFAFA] hover:bg-[#333] first:rounded-t-xl last:rounded-b-xl cursor-pointer">Home</a>
                  <a href="/services/" class="block px-4 py-3 hover:text-[#FAFAFA] hover:bg-[#333] first:rounded-t-xl last:rounded-b-xl cursor-pointer">Services</a>
                  <a href="/areas/" class="block px-4 py-3 hover:text-[#FAFAFA] hover:bg-[#333] first:rounded-t-xl last:rounded-b-xl cursor-pointer">Areas</a>
                  <a href="/projects/" class="block px-4 py-3 hover:text-[#FAFAFA] hover:bg-[#333] first:rounded-t-xl last:rounded-b-xl cursor-pointer">Projects</a>
                  <a href="/about/" class="block px-4 py-3 hover:text-[#FAFAFA] hover:bg-[#333] first:rounded-t-xl last:rounded-b-xl cursor-pointer">About</a>
                  <a href="/contact/" class="block px-4 py-3 hover:text-[#FAFAFA] hover:bg-[#333] first:rounded-t-xl last:rounded-b-xl cursor-pointer">Contact Us</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </header>
    </slot>

    <slot />

    <footer>
      <div class="relative isolate mx-auto min-h-fit w-full py-12 grid max-w-screen-xl grid-cols-1 gap-10 px-8 pb-12 pt-20 text-lg lg:grid-flow-col lg:grid-cols-none">
        <div class="order-1 lg:order-none text-[#FAFAFA] flex flex-col items-start justify-start text-left">
          <img src="/img/logo-full.png" alt="Sun Synergy Contracts Logo" width="809" height="460" class="h-10 w-auto" />
          <p class="mt-2 whitespace-nowrap text-sm">Together we create your happy place</p>
          <div class="mb-5 mt-5 text-sm space-y-2">
            <p>17C, Jalan PJS 1/33<br />Taman Petaling Utama<br />46150 Petaling Jaya, Selangor<br />Malaysia.</p>
            <p>
              <a
                class="hover:text-gray-400"
                href="tel:+60128773999"
                onclick="window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'call_click',phone:'+60128773999',location:'footer'});"
              >+60 12-877 3999</a>
            </p>
            <p>
              <a
                class="hover:text-gray-400"
                href="mailto:info@sunsynergycontracts.com.my"
                onclick="window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'email_click',email:'info@sunsynergycontracts.com.my',location:'footer'});"
              >info@sunsynergycontracts.com.my</a>
            </p>
          </div>
          <p class="opacity-60 mt-4 whitespace-nowrap text-xs">© {new Date().getFullYear()} Sun Synergy Contracts &middot; SSM: 1382832-A</p>
        </div>
        <div>
          <div class="text-eyebrow-medium mb-6 text-white/60 text-sm font-semibold uppercase tracking-wider">SERVICES</div>
          <ul class="space-y-4 text-[#FAFAFA] text-sm">
            <li><a href="/services/home-renovation/" class="hover:text-gray-400 transition-colors">Home Renovation</a></li>
            <li><a href="/services/interior-design/" class="hover:text-gray-400 transition-colors">Interior Design</a></li>
            <li><a href="/services/commercial-renovation/" class="hover:text-gray-400 transition-colors">Commercial Renovation</a></li>
            <li><a href="/services/office-renovation/" class="hover:text-gray-400 transition-colors">Office Renovation</a></li>
            <li><a href="/services/kitchen-cabinetry/" class="hover:text-gray-400 transition-colors">Carpentry & Joinery</a></li>
            <li><a href="/services/premium-flooring/" class="hover:text-gray-400 transition-colors">Premium Flooring</a></li>
            <li><a href="/services/wet-works-plumbing/" class="hover:text-gray-400 transition-colors">Wet Works & Plumbing</a></li>
            <li><a href="/services/aluminium-glass/" class="hover:text-gray-400 transition-colors">Aluminium & Glass</a></li>
            <li><a href="/services/authority-submission/" class="hover:text-gray-400 transition-colors">Authority Submission</a></li>
          </ul>
        </div>
        <div>
          <a href="/areas/" class="text-eyebrow-medium mb-6 block text-white/60 text-sm font-semibold uppercase tracking-wider hover:text-gray-400 transition-colors">AREAS</a>
          <ul class="space-y-4 text-[#FAFAFA] text-sm">
            <li><a href="/areas/petaling-jaya/" class="hover:text-gray-400 transition-colors">Petaling Jaya</a></li>
            <li><a href="/areas/subang-jaya-usj/" class="hover:text-gray-400 transition-colors">Subang Jaya & USJ</a></li>
            <li><a href="/areas/puchong/" class="hover:text-gray-400 transition-colors">Puchong</a></li>
            <li><a href="/areas/kuala-lumpur/" class="hover:text-gray-400 transition-colors">Kuala Lumpur</a></li>
          </ul>
        </div>
        <div>
          <div class="text-eyebrow-medium mb-6 text-white/60 text-sm font-semibold uppercase tracking-wider">MISCELLANEOUS</div>
          <ul class="space-y-4 text-[#FAFAFA] text-sm">
            <li><a href="/about/" class="hover:text-gray-400 transition-colors">About Us</a></li>
            <li><a href="/faqs/" class="hover:text-gray-400 transition-colors">FAQs</a></li>
            <li><a href="/blog/" class="hover:text-gray-400 transition-colors">Blog</a></li>
            <li><a href="/projects/" class="hover:text-gray-400 transition-colors">All Projects</a></li>
            <li><a href="/contact/" class="hover:text-gray-400 transition-colors">Contact Us</a></li>
            <li><a href="/legal/terms/" class="hover:text-gray-400 transition-colors">Terms of Use</a></li>
            <li><a href="/legal/privacy/" class="hover:text-gray-400 transition-colors">Privacy Policy</a></li>
          </ul>
        </div>
        <div>
          <div class="text-eyebrow-medium mb-6 text-white/60 text-sm font-semibold uppercase tracking-wider">SUN SYNERGY</div>
          <ul class="space-y-4 text-[#FAFAFA] text-sm">
            <li><a href="https://www.sunsynergy.my/products/" target="_blank" rel="noopener" class="hover:text-gray-400 transition-colors">Products</a></li>
            <li><a href="https://www.sunsynergy.my/projects/" target="_blank" rel="noopener" class="hover:text-gray-400 transition-colors">Projects</a></li>
          </ul>
        </div>
      </div>
      <div class="mx-auto max-w-screen-xl px-8 pb-8 flex justify-end">
        <p class="opacity-60 text-xs">Website by <a href="https://zanordigital.com" target="_blank" rel="noopener" class="hover:text-gray-400 transition-colors">Zanor Digital</a></p>
      </div>
    </footer>

    <WhatsAppButton message={whatsappMessage} />
  </body>
</html>
