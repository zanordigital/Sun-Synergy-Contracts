---
interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mx-auto max-w-screen-xl px-4 sm:px-8 pt-28 pb-4">
  <ol class="flex items-center gap-2 text-sm text-[#FAFAFA]/60">
    <li>
      <a href="/" class="hover:text-[#FAFAFA] transition-colors">Home</a>
    </li>
    {items.map((item, i) => (
      <>
        <li aria-hidden="true" class="select-none">/</li>
        <li>
          {i === items.length - 1 ? (
            <span class="text-[#FAFAFA]" aria-current="page">{item.name}</span>
          ) : (
            <a href={item.url} class="hover:text-[#FAFAFA] transition-colors">{item.name}</a>
          )}
        </li>
      </>
    ))}
  </ol>
</nav>
