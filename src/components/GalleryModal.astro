---
import { getCollection } from 'astro:content';
const allProjects = await getCollection('projects');
const projectsJson = JSON.stringify(
  allProjects.map((p) => ({
    slug: p.id,
    name: p.data.name,
    folderName: p.data.folderName,
    images: p.data.images,
  }))
);
---

<div x-data={`{ projects: ${projectsJson} }`} x-show="isGalleryModalOpen" class="relative z-[90]" aria-labelledby="modal-title" role="dialog" aria-modal="true">
  <div
    x-show="isGalleryModalOpen"
    x-transition:enter="ease-out duration-300"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="ease-in duration-200"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="fixed inset-0 bg-[#333] bg-opacity-75 transition-opacity"
  ></div>

  <div
    x-data="{ indexMainPicture: 0 }"
    x-show="isGalleryModalOpen"
    class="fixed inset-0 z-[90] w-screen overflow-y-auto"
  >
    <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
      <div
        @click.outside="isGalleryModalOpen = false; indexMainPicture = 0; document.getElementById('gallery-grid').scrollLeft = 0;"
        x-show="isGalleryModalOpen"
        x-transition:enter="ease-out duration-300"
        x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
        x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
        x-transition:leave="ease-in duration-200"
        x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
        x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
        class="relative transform overflow-hidden rounded-lg bg-white px-4 pb-4 pt-5 text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-7xl sm:p-6"
      >
        <div class="absolute right-0 top-0 pr-4 pt-4 block">
          <button
            @click="isGalleryModalOpen = false; indexMainPicture = 0; document.getElementById('gallery-grid').scrollLeft = 0;"
            type="button"
            class="rounded-md text-[#333] hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-[#333] focus:ring-offset-2"
          >
            <span class="sr-only">Close</span>
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <template x-for="project in projects.filter(p => p.slug === idGallery)" :key="project.slug">
          <div class="grid gap-4 mt-6">
            <div class="aspect-h-7 aspect-w-10">
              <img
                loading="lazy"
                class="mx-auto rounded-lg object-cover max-h-[60vh] w-auto"
                :src="'/img/projects/' + project.folderName + '/' + indexMainPicture + '.jpg'"
                :alt="'Picture ' + (indexMainPicture + 1) + ' of ' + project.name"
              />
            </div>
            <div class="grid grid-flow-col grid-rows-1 justify-start space-x-2 overflow-x-scroll pb-5" id="gallery-grid">
              <template x-for="i in Array.from({ length: project.images }, (_, k) => k)" :key="project.slug + '-' + i">
                <div @click="indexMainPicture = i" class="group cursor-pointer block w-40 h-28 rounded-lg">
                  <img
                    loading="lazy"
                    :src="'/img/projects/' + project.folderName + '/' + i + '.jpg'"
                    :alt="'Picture ' + (i + 1) + ' of ' + project.name"
                    :class="indexMainPicture === i && 'border-4 border-[#333] opacity-75'"
                    class="pointer-events-none rounded-lg object-cover group-hover:opacity-75 w-40 h-28"
                  />
                </div>
              </template>
            </div>
          </div>
        </template>
      </div>
    </div>
  </div>
</div>
