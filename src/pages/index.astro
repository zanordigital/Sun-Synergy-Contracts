---
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryModal from '../components/GalleryModal.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects.filter((p) => p.data.featured);
---

<BaseLayout
  title="Sun Synergy Contracts - Interior Design & Renovation Klang Valley"
  description="Creative and modern interior design solutions for commercial and residential spaces in Klang Valley. Established 1999."
>
  <main class="min-h-screen w-full space-y-5">

    <!-- Hero section -->
    <section>
      <div class="relative w-full min-h-[450px] pt-24 xl:pt-0 pb-8 place-items-center">
        <!-- Mobile hero text -->
        <div class="block md:hidden">
          <div class="mx-auto grid w-full max-w-[50rem] gap-4 px-4 pt-12 text-center xl:pt-32">
            <h1 class="text-4xl mx-auto w-2/3 font-semibold lg:w-auto text-[#FAFAFA] font-serif">
              Together we create your happy place.
            </h1>
            <p class="mt-2 px-4 text-sm font-normal text-[#FAFAFA]">
              According to our clients' preferences, we provide highly creative and modern interior design solutions for commercial and residential spaces with a classic touch to meet their demands and expectations.
            </p>
          </div>
          <div class="mt-4 mx-auto h-6 relative flex flex-col space-y-6 items-center place-self-start whitespace-nowrap text-left text-xs text-[#FAFAFA]/60 sm:text-sm">
            <span>More than 40+ projects delivered...</span>
          </div>
          <a href="/contact" class="w-fit text-center mt-4 block mx-auto rounded-md bg-transparent border-gray-300 border-[0.2px] px-3.5 py-2.5 text-sm font-bold text-[#FAFAFA] ring-1 ring-inset ring-gray-300 hover:bg-gray-200 hover:text-[#333] transition-all duration-150 ease-linear">Speak with us</a>
        </div>

        <!-- Desktop hero text -->
        <div class="hidden md:block">
          <div class="mx-auto grid w-full max-w-[50rem] place-items-center gap-8 px-4 pt-12 xl:pt-32 text-center">
            <h1 class="mx-auto font-serif text-[#FAFAFA] text-6xl font-bold">
              Together we create your happy place.
            </h1>
            <p class="px-4 font-normal text-[#FAFAFA]/60 max-w-[600px]">
              According to our clients' preferences, we provide highly creative and modern interior design solutions for commercial and residential spaces with a classic touch to meet their demands and expectations.
            </p>
            <a href="/contact" class="mt-4 block rounded-md bg-transparent border-gray-300 border-[0.2px] px-3.5 py-2.5 font-bold text-[#FAFAFA] ring-1 ring-inset ring-gray-300 hover:bg-gray-200 hover:text-[#333] transition-all duration-150 ease-linear">Speak with us</a>
          </div>
        </div>

        <!-- Background video -->
        <div class="after:bg-[linear-gradient(0deg,transparent,transparent),linear-gradient(90deg,rgba(0,0,0,.7),transparent),linear-gradient(180deg,transparent,#000)] after:contents[''] absolute inset-0 isolate -z-10 after:absolute after:inset-0">
          <video id="cover-video" preload="auto" width="100%" height="100%" muted autoplay loop playsinline class="min-w-[90vw] lg:min-w-[50vw] absolute left-0 top-0 -z-10 h-full w-full object-cover">
            <source src="/video/SunSynergy_2.mp4" type="video/mp4" />
          </video>
          <img id="cover-gif" class="hidden min-w-[90vw] lg:min-w-[50vw] absolute left-0 top-0 -z-10 h-full w-full object-cover" src="/video/SunSynergy_1-3.gif" alt="" />
        </div>
      </div>
    </section>

    <!-- Featured projects grid -->
    <section class="bg-black">
      <div class="mx-auto max-w-screen-xl overflow-hidden px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
        <div class="grid gap-x-6 gap-y-10 grid-cols-[repeat(auto-fill,minmax(333px,1fr))] lg:gap-x-8 items-start">
          {featuredProjects.map((project) => (
            <a
              @click={`idGallery = '${project.id}'; isGalleryModalOpen = true`}
              class="cursor-pointer group text-sm flex flex-col h-full"
            >
              <div class="w-full overflow-hidden rounded-lg bg-gray-100 group-hover:opacity-75 transition-all duration-150 ease-linear">
                <img
                  loading="lazy"
                  src={`/img/projects/${project.data.folderName}/0.jpg`}
                  alt={`${project.data.name} project by Sun Synergy Contracts`}
                  class="w-full aspect-[4/3] object-cover object-center"
                />
              </div>
              <h3 class="mt-4 font-medium text-[#FAFAFA] text-lg">{project.data.name}</h3>
              <div class="flex flex-row items-center gap-2 mt-1">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-gray-400">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm.75-13a.75.75 0 0 0-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 0 0 0-1.5h-3.25V5Z" clip-rule="evenodd" />
                </svg>
                <p class="font-medium text-gray-400">{project.data.duration}</p>
              </div>
              <p class="italic text-gray-300 line-clamp-4 hyphens-auto mt-2">{project.data.description}</p>
            </a>
          ))}
        </div>
        <a href="/projects" class="mt-10 mx-auto w-fit text-center block rounded-md bg-transparent border-gray-300 border-[0.2px] px-3.5 py-2.5 font-bold text-[#FAFAFA] ring-1 ring-inset ring-gray-300 hover:bg-gray-200 hover:text-[#333] transition-all duration-150 ease-linear">See all projects</a>
      </div>
    </section>

    <!-- Why choose us -->
    <section class="bg-[#FAFAFA]">
      <div class="mx-auto max-w-screen-xl overflow-hidden px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
        <h2 class="mb-4 text-sm font-bold uppercase opacity-60">WHY CHOOSE US</h2>
        <div class="mb-20 max-w-[600px]">
          <h3 class="w-full max-w-[600px] font-serif text-3xl font-black lg:text-6xl">Together we create your happy place</h3>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-11">
          <div>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-14 h-14 mb-4 text-gray-500">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
            </svg>
            <h4 class="text-xl font-extrabold lg:text-2xl">Extensive Experience</h4>
            <p class="w-full text-lg font-medium lg:text-xl lg:leading-8">Our company started as a builder ever since 1999, therefore it's no doubt we are experience in this construction line.</p>
          </div>
          <div>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-14 h-14 mb-4 text-gray-500">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88" />
            </svg>
            <h4 class="text-xl font-extrabold lg:text-2xl">No Hidden Cost</h4>
            <p class="w-full text-lg font-medium lg:text-xl lg:leading-8">We always emphasise on transparency on all our quote. Therefore, you can be assure that there will be no hidden cost between our deals.</p>
          </div>
          <div>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-14 h-14 mb-4 text-gray-500">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-6h.008v.008H12v-.008zM12 15h.008v.008H12V15zm0 2.25h.008v.008H12v-.008zM9.75 15h.008v.008H9.75V15zm0 2.25h.008v.008H9.75v-.008zM7.5 15h.008v.008H7.5V15zm0 2.25h.008v.008H7.5v-.008zm6.75-4.5h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V15zm0 2.25h.008v.008h-.008v-.008zm2.25-4.5h.008v.008H16.5v-.008zm0 2.25h.008v.008H16.5V15z" />
            </svg>
            <h4 class="text-xl font-extrabold lg:text-2xl">Timeline</h4>
            <p class="w-full text-lg font-medium lg:text-xl lg:leading-8">We understand how important a time factor for a business person like you therefore, timeline plays an important rules in our works.</p>
          </div>
          <div>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-14 h-14 mb-4 text-gray-500">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
            </svg>
            <h4 class="text-xl font-extrabold lg:text-2xl">Makeover Loan</h4>
            <p class="w-full text-lg font-medium lg:text-xl lg:leading-8">We have currently offer some great instalment method for any design project by us. Just come and talk to us.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="bg-black">
      <div class="px-6 py-24 sm:py-32 lg:px-8">
        <figure class="mx-auto max-w-2xl">
          <blockquote class="mt-10 text-xl font-semibold leading-8 tracking-tight text-[#FAFAFA] sm:text-2xl sm:leading-9">
            <p>"At Sun Synergy Contracts, we believe that every commercial space has the potential to be an inspiring and productive environment. We combine cutting-edge design with a commitment to quality craftsmanship to transform your vision into reality. Let us help you create a space that reflects your brand and empowers your team."</p>
          </blockquote>
          <figcaption class="mt-10 flex items-center gap-x-6">
            <img loading="lazy" class="h-12 w-12 rounded-full bg-gray-50" src="/img/catherine.jpg" alt="Catherine Ng, Design Director at Sun Synergy Contracts" />
            <div class="text-sm leading-6">
              <div class="font-semibold text-[#FAFAFA]">Catherine Ng</div>
              <div class="mt-0.5 text-[#FAFAFA]">Design Director</div>
            </div>
          </figcaption>
        </figure>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-[#FAFAFA]">
      <div class="px-6 py-24 sm:px-6 sm:py-32 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-4xl font-serif font-bold tracking-tight text-gray-900 sm:text-5xl">Let us create your happy place.<br />Together.</h2>
          <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-gray-600">We provide highly creative and modern interior design solutions for commercial and residential spaces with a classic touch to meet their demands and expectations.</p>
          <div class="mt-10">
            <a href="/contact" class="rounded-md bg-[#333] px-3.5 py-2.5 text-lg font-semibold text-white shadow-sm hover:bg-gray-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-800">Speak with us</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <GalleryModal />
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    setTimeout(() => {
      const video = document.getElementById('cover-video') as HTMLVideoElement;
      const gif = document.getElementById('cover-gif') as HTMLImageElement;
      if (video && gif && video.played.length === 0) {
        video.classList.add('hidden');
        gif.classList.remove('hidden');
      }
    }, 1000);
  });
</script>
