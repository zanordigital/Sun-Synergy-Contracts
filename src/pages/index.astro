---
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryModal from '../components/GalleryModal.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects.filter((p) => p.data.featured).slice(0, 6);

const allServices = await getCollection('services');
const allLocations = await getCollection('locations');

const serviceOrder = ['home-renovation', 'interior-design', 'commercial-renovation', 'kitchen-cabinetry', 'premium-flooring', 'wet-works-plumbing', 'aluminium-glass', 'authority-submission'];
const sortedServices = allServices.sort((a, b) => serviceOrder.indexOf(a.data.slug) - serviceOrder.indexOf(b.data.slug));

const faqEntries = await getCollection('faqs');
const topFaqs = faqEntries.slice(0, 5).map((e) => ({ question: e.data.question, answer: e.data.answer }));

const serviceIcons: Record<string, string> = {
  'home-renovation': 'M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25',
  'interior-design': 'M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42',
  'commercial-renovation': 'M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21',
  'kitchen-cabinetry': 'M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0H3',
  'premium-flooring': 'M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z',
  'wet-works-plumbing': 'M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 1-6.23-.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5',
  'aluminium-glass': 'M9 4.5v15m6-15v15m-10.875 0h15.75c.621 0 1.125-.504 1.125-1.125V5.625c0-.621-.504-1.125-1.125-1.125H4.125C3.504 4.5 3 5.004 3 5.625v12.75c0 .621.504 1.125 1.125 1.125Z',
  'authority-submission': 'M11.35 3.836c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m8.9-4.414c.376.023.75.05 1.124.08 1.131.094 1.976 1.057 1.976 2.192V16.5A2.25 2.25 0 0 1 18 18.75h-2.25m-7.5-10.5H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V18.75m-7.5-10.5h6.375c.621 0 1.125.504 1.125 1.125v9.375m-8.25-3 1.5 1.5 3-3.75',
};
---

<BaseLayout
  title="Renovation Contractor & Interior Designer Malaysia"
  description="CIDB G4 renovation contractor and interior design firm in Petaling Jaya, serving the Klang Valley and across Malaysia since 2016. Free consultation."
  schemaPage="home"
>
  <main class="min-h-screen w-full">

    <!-- Hero with video background -->
    <section class="relative isolate w-full min-h-[600px] flex items-end pb-16 pt-40">
      <div class="absolute inset-0 -z-10 isolate after:absolute after:inset-0 after:bg-[linear-gradient(0deg,transparent,transparent),linear-gradient(90deg,rgba(0,0,0,.7),transparent),linear-gradient(180deg,transparent,#000)]">
        <video id="cover-video" preload="auto" width="100%" height="100%" muted autoplay loop playsinline class="absolute inset-0 -z-10 h-full w-full object-cover">
          <source src="/video/SunSynergy_2.mp4" type="video/mp4" />
        </video>
        <img id="cover-gif" class="hidden absolute inset-0 -z-10 h-full w-full object-cover" src="/video/SunSynergy_1-3.gif" alt="" />
      </div>
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 w-full">
        <p class="text-xs text-[#FAFAFA]/60 uppercase mb-3">CIDB G4 certified | Founded 2016 | Petaling Jaya HQ, serving all Malaysia</p>
        <h1 class="text-4xl md:text-5xl xl:text-6xl text-[#FAFAFA] font-serif font-bold max-w-3xl">Renovation Contractor &amp; Interior Designer in Petaling Jaya</h1>
        <p class="mt-4 text-lg text-[#FAFAFA]/80 max-w-2xl">From home renovations to commercial fit-outs, bespoke carpentry to authority submissions - one accountable contractor delivers your entire project. Headquartered in Petaling Jaya, working across the Klang Valley and Malaysia nationwide.</p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="/contact"
            class="rounded-md bg-[#FAFAFA] px-5 py-3 text-sm font-bold text-[#333] shadow-md hover:bg-[#333] hover:text-[#FAFAFA] transition-all duration-150"
          >Get a free quote</a>
          <a
            href="https://wa.me/60128773999?text=Hi%2C%20I%27d%20like%20to%20enquire%20about%20your%20renovation%20services."
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-md bg-[#25D366] px-5 py-3 text-sm font-bold text-white shadow-md hover:bg-[#1da851] transition-all duration-150"
            onclick="window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'whatsapp_click',location:'home_hero'});"
          >WhatsApp us</a>
        </div>
      </div>
    </section>

    <!-- Trust bar -->
    <section class="bg-[#111] border-y border-[#333]">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-6 flex flex-wrap gap-6 items-center justify-between">
        <div class="flex items-center gap-3 text-[#FAFAFA]">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#FAFAFA]/60 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
          </svg>
          <span class="text-sm font-semibold">CIDB G4 Certified</span>
        </div>
        <div class="flex items-center gap-3 text-[#FAFAFA]">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#FAFAFA]/60 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
          </svg>
          <span class="text-sm font-semibold">PJ HQ, Nationwide Reach</span>
        </div>
        <div class="flex items-center gap-3 text-[#FAFAFA]">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#FAFAFA]/60 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
          </svg>
          <span class="text-sm font-semibold">Fixed Timeline & Price</span>
        </div>
        <div class="flex items-center gap-3 text-[#FAFAFA]">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#FAFAFA]/60 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" />
          </svg>
          <span class="text-sm font-semibold">One Contractor, All Trades</span>
        </div>
      </div>
    </section>

    <!-- Professional memberships strip -->
    <section class="bg-[#0a0a0a] border-b border-[#222]">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-5 flex flex-wrap items-center justify-center gap-x-10 gap-y-4">
        <span class="text-xs text-[#FAFAFA]/40 uppercase tracking-wider font-semibold flex-shrink-0">Member of</span>
        <img src="/img/associations/miid-Web-Logo.png" alt="MIID - Malaysian Institute of Interior Designers" class="h-8 object-contain opacity-60 hover:opacity-100 transition-opacity" loading="lazy" />
        <img src="/img/associations/Cidb-Malaysia-Logo.png" alt="CIDB Malaysia" class="h-8 object-contain opacity-60 hover:opacity-100 transition-opacity" loading="lazy" />
        <img src="/img/associations/MBAM_logo.png" alt="Master Builders Association Malaysia" class="h-8 object-contain opacity-60 hover:opacity-100 transition-opacity" loading="lazy" />
        <img src="/img/associations/MIIP Logo.PNG" alt="MIIP - Malaysian Interior Industry Partners" class="h-8 object-contain opacity-60 hover:opacity-100 transition-opacity" loading="lazy" />
      </div>
    </section>

    <!-- Services grid -->
    <section class="bg-black">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24">
        <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">What we do</p>
        <div class="flex items-end justify-between mb-12 flex-wrap gap-4">
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#FAFAFA] max-w-2xl">Eight service lines, one accountable contractor</h2>
          <a href="/services" class="text-sm font-semibold text-[#FAFAFA] hover:text-gray-300 transition-colors">View all services &rarr;</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {sortedServices.map((service) => (
            <a href={`/services/${service.data.slug}`} class="group block p-8 border border-[#333] rounded-lg hover:border-[#FAFAFA]/40 hover:bg-[#111] transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-[#FAFAFA]/60 mb-6 group-hover:text-[#FAFAFA] transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d={serviceIcons[service.data.slug] || 'M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z'} />
              </svg>
              <h3 class="text-xl font-bold text-[#FAFAFA] mb-3 group-hover:text-gray-300 transition-colors">{service.data.title}</h3>
              <p class="text-sm text-[#FAFAFA]/70 leading-relaxed mb-4">{service.data.heroSubhead}</p>
              {service.data.priceFromMYR && (
                <p class="text-xs font-semibold text-[#FAFAFA]/50 mb-4">From RM {service.data.priceFromMYR.toLocaleString()}</p>
              )}
              <p class="text-xs font-semibold text-[#FAFAFA]/60 group-hover:text-[#FAFAFA] transition-colors">Learn more &rarr;</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Why choose us / problem-solution -->
    <section class="bg-[#111]">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 rounded-2xl overflow-hidden border border-[#333]">

          <!-- Left: problems -->
          <div class="bg-[#0a0a0a] p-10 sm:p-14">
            <p class="text-xs text-red-400/80 uppercase tracking-widest mb-6">The common problem</p>
            <h2 class="text-2xl md:text-3xl font-serif font-bold text-[#FAFAFA] mb-10 leading-snug">Why most renovation projects in Malaysia go wrong</h2>
            <ul class="space-y-6">
              {[
                'Multiple contractors who blame each other when something goes wrong on site',
                'Hidden costs that surface mid-project after the contract is signed',
                'Timeline slippage with no accountability and no recourse',
                'Unlicensed builders with no CIDB certification and no warranty on the work',
              ].map((problem) => (
                <li class="flex gap-4 items-start">
                  <span class="flex-shrink-0 mt-0.5 w-6 h-6 rounded-full bg-red-500/10 border border-red-500/30 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                    </svg>
                  </span>
                  <span class="text-[#FAFAFA]/70 leading-relaxed">{problem}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Right: solution -->
          <div class="bg-[#FAFAFA] p-10 sm:p-14 flex flex-col justify-between">
            <div>
              <p class="text-xs text-gray-500 uppercase tracking-widest mb-6">Our approach</p>
              <h2 class="text-2xl md:text-3xl font-serif font-bold text-gray-900 mb-8 leading-snug">One contract. One accountable party. One signature on every defect.</h2>
              <ul class="space-y-5 mb-8">
                {[
                  'Every trade your project needs under one CIDB G4 licensed roof',
                  'Fully itemised quotation before work begins - no hidden costs',
                  'Written timeline with milestone payments built into the contract',
                  'Joint handover walkthrough - defects fixed before final payment',
                ].map((point) => (
                  <li class="flex gap-4 items-start">
                    <span class="flex-shrink-0 mt-0.5 w-6 h-6 rounded-full bg-gray-900/10 border border-gray-900/20 flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-gray-700" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                      </svg>
                    </span>
                    <span class="text-gray-700 leading-relaxed">{point}</span>
                  </li>
                ))}
              </ul>
            </div>
            <a href="/about" class="inline-flex items-center gap-2 text-sm font-semibold text-gray-900 hover:text-gray-600 transition-colors">
              More about how we work
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- Featured projects -->
    <section class="bg-black">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24">
        <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">Selected projects</p>
        <div class="flex items-end justify-between mb-12 flex-wrap gap-4">
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#FAFAFA] max-w-2xl">Recent work across the Klang Valley</h2>
          <a href="/projects" class="text-sm font-semibold text-[#FAFAFA] hover:text-gray-300 transition-colors">See all projects &rarr;</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredProjects.map((project) => (
            <a href={`/projects/${project.id}`} class="group block">
              <div class="overflow-hidden rounded-lg bg-gray-900">
                <img
                  loading="lazy"
                  src={`/img/projects/${project.data.folderName}/0.jpg`}
                  alt={`${project.data.name} project by Sun Synergy Contracts`}
                  class="w-full aspect-[4/3] object-cover object-center group-hover:scale-105 transition-transform duration-300"
                />
              </div>
              <h3 class="mt-4 font-semibold text-[#FAFAFA] group-hover:text-gray-300 transition-colors">{project.data.name}</h3>
              {project.data.city && (
                <p class="text-sm text-[#FAFAFA]/60 mt-1">{project.data.city} &bull; {project.data.duration}</p>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="bg-[#FAFAFA]">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24">
        <p class="text-xs text-gray-500 uppercase mb-4">How we work</p>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-gray-900 mb-12 max-w-2xl">A predictable, transparent process from first call to handover</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-8">
          <div>
            <div class="text-5xl font-black text-gray-100 leading-none mb-4 select-none">01</div>
            <h3 class="text-base font-bold text-gray-900 mb-2">Free consultation</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Site visit and goal-setting conversation, no obligation.</p>
          </div>
          <div>
            <div class="text-5xl font-black text-gray-100 leading-none mb-4 select-none">02</div>
            <h3 class="text-base font-bold text-gray-900 mb-2">Design & quote</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Detailed concept and fully itemised quotation with no hidden costs.</p>
          </div>
          <div>
            <div class="text-5xl font-black text-gray-100 leading-none mb-4 select-none">03</div>
            <h3 class="text-base font-bold text-gray-900 mb-2">Contract & schedule</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Written contract with fixed timeline and milestone payments.</p>
          </div>
          <div>
            <div class="text-5xl font-black text-gray-100 leading-none mb-4 select-none">04</div>
            <h3 class="text-base font-bold text-gray-900 mb-2">Construction</h3>
            <p class="text-gray-600 text-sm leading-relaxed">All trades sequenced and supervised by a dedicated site manager.</p>
          </div>
          <div>
            <div class="text-5xl font-black text-gray-100 leading-none mb-4 select-none">05</div>
            <h3 class="text-base font-bold text-gray-900 mb-2">Handover</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Joint walkthrough, defect rectification, then final payment.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonial / Catherine -->
    <section class="bg-black">
      <div class="px-6 py-24 sm:py-32 lg:px-8">
        <figure class="mx-auto max-w-2xl">
          <blockquote class="text-xl font-serif leading-9 tracking-tight text-[#FAFAFA] sm:text-2xl">
            <p>"Every project we sign is a promise. We are the only signature on the contract, the only number you call, and the only party answerable for the result. That is how we have run this firm since 2016, and it is why our clients keep referring us to their friends and partners."</p>
          </blockquote>
          <figcaption class="mt-10 flex items-center gap-x-6">
            <img loading="lazy" class="h-12 w-12 rounded-full bg-gray-50 object-cover" src="/img/catherine.jpg" alt="Catherine Ng, Design Director at Sun Synergy Contracts" />
            <div class="text-sm leading-6">
              <div class="font-semibold text-[#FAFAFA]">Catherine Ng</div>
              <div class="mt-0.5 text-[#FAFAFA]/60">Design Director, Sun Synergy Contracts</div>
            </div>
          </figcaption>
        </figure>
      </div>
    </section>

    <!-- Areas served -->
    <section class="bg-[#111]">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24">
        <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">Where we work</p>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#FAFAFA] mb-6 max-w-2xl">Klang Valley primary, Malaysia nationwide</h2>
        <p class="text-[#FAFAFA]/70 leading-relaxed max-w-2xl mb-12">Our four primary service areas are Petaling Jaya, Subang Jaya &amp; USJ, Puchong, and Kuala Lumpur - we run sites in these cities daily. We also accept projects across the wider Klang Valley (Shah Alam, Klang, Cyberjaya, Kajang) and undertake high-value commercial and residential commissions throughout Malaysia.</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {allLocations.map((location) => (
            <a href={`/areas/${location.data.slug}`} class="block p-6 border border-[#333] rounded-lg hover:border-[#FAFAFA]/40 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-[#FAFAFA]/40 mb-3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
              </svg>
              <h3 class="font-semibold text-[#FAFAFA]">{location.data.name}</h3>
              <p class="text-xs text-[#FAFAFA]/50 mt-1">Primary area</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ teaser -->
    {topFaqs.length > 0 && (
      <section class="bg-[#111]">
        <div class="mx-auto max-w-3xl px-4 sm:px-8 py-16 sm:py-24">
          <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">Common questions</p>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#FAFAFA] mb-12">Frequently asked questions</h2>
          <dl class="divide-y divide-[#333]" x-data="{ open: null }">
            {topFaqs.map((faq, i) => (
              <div class="py-5">
                <dt>
                  <button
                    type="button"
                    class="flex w-full items-center justify-between gap-4 text-left"
                    x-on:click={`open = open === ${i} ? null : ${i}`}
                    :aria-expanded={`open === ${i}`}
                  >
                    <span class="text-base font-semibold text-[#FAFAFA]">{faq.question}</span>
                    <span class="flex-shrink-0 text-[#FAFAFA]/40" :class={`open === ${i} ? 'rotate-45' : ''`} style="transition: transform 0.2s ease;">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                      </svg>
                    </span>
                  </button>
                </dt>
                <dd
                  x-show={`open === ${i}`}
                  x-transition:enter="transition ease-out duration-200"
                  x-transition:enter-start="opacity-0 -translate-y-1"
                  x-transition:enter-end="opacity-100 translate-y-0"
                  x-transition:leave="transition ease-in duration-150"
                  x-transition:leave-start="opacity-100 translate-y-0"
                  x-transition:leave-end="opacity-0 -translate-y-1"
                  class="mt-4 pr-10"
                >
                  <p class="text-[#FAFAFA]/70 leading-relaxed text-sm">{faq.answer}</p>
                </dd>
              </div>
            ))}
          </dl>
          <div class="mt-10 pt-6 border-t border-[#333]">
            <a href="/faqs" class="text-sm font-semibold text-[#FAFAFA] hover:text-gray-300 transition-colors">See all FAQs &rarr;</a>
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="bg-[#FAFAFA]">
      <div class="px-6 py-24 sm:px-6 sm:py-32 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-4xl font-serif font-bold tracking-tight text-gray-900 sm:text-5xl">Ready to start your renovation?</h2>
          <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-gray-600">A free site visit, an honest assessment of what is achievable in your budget, and a fully itemised quotation - that is how every Sun Synergy project starts.</p>
          <div class="mt-10 flex flex-wrap justify-center gap-4">
            <a href="/contact" class="rounded-md bg-[#333] px-5 py-3 text-lg font-semibold text-white shadow-sm hover:bg-gray-700 transition-colors">Get a free quote</a>
            <a
              href="https://wa.me/60128773999?text=Hi%2C%20I%27d%20like%20to%20enquire%20about%20your%20renovation%20services."
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-md bg-[#25D366] px-5 py-3 text-lg font-semibold text-white shadow-sm hover:bg-[#1da851] transition-colors"
              onclick="window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'whatsapp_click',location:'home_cta'});"
            >WhatsApp us</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <GalleryModal />
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    setTimeout(() => {
      const video = document.getElementById('cover-video') as HTMLVideoElement;
      const gif = document.getElementById('cover-gif') as HTMLImageElement;
      if (video && gif && video.played.length === 0) {
        video.classList.add('hidden');
        gif.classList.remove('hidden');
      }
    }, 1000);
  });
</script>
