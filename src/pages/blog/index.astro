---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const categoryLabels: Record<string, string> = {
  'renovation-tips': 'Renovation Tips',
  'interior-design': 'Interior Design',
  'project-showcase': 'Project Showcase',
  'cost-guide': 'Cost Guide',
  'contractor-advice': 'Contractor Advice',
};

function formatDate(date: Date) {
  return date.toLocaleDateString('en-MY', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout
  title="Renovation Insights & Advice | Sun Synergy Contracts Blog"
  description="Expert renovation advice, cost guides and interior design insights from Sun Synergy Contracts, a CIDB G4 contractor serving Klang Valley homeowners."
  schemaPage="other"
  schemaBreadcrumbs={[{ name: 'Blog', url: '/blog' }]}
  whatsappMessage="Hi, I'd like to enquire about renovation services in the Klang Valley."
>
  <main class="min-h-screen w-full">

    <!-- Hero -->
    <section class="relative isolate w-full min-h-[400px] flex items-end pb-16 pt-36 overflow-hidden bg-black">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 w-full">
        <p class="text-xs text-[#FAFAFA]/60 uppercase mb-3">Renovation Insights</p>
        <h1 class="text-4xl md:text-5xl xl:text-6xl text-[#FAFAFA] font-serif font-bold max-w-3xl">Advice from the Job Site</h1>
        <p class="mt-4 text-lg text-[#FAFAFA]/80 max-w-2xl">Cost guides, contractor advice, and renovation insights from the team at Sun Synergy Contracts - written from experience, not theory.</p>
      </div>
    </section>

    <!-- Posts grid -->
    <section class="bg-[#111]">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {sortedPosts.map((post) => (
            <a href={`/blog/${post.id}/`} class="group flex flex-col">
              {post.data.heroImage ? (
                <div class="overflow-hidden rounded-lg bg-gray-900">
                  <img
                    loading="lazy"
                    src={post.data.heroImage}
                    alt={post.data.title}
                    class="w-full aspect-[16/9] object-cover object-center group-hover:scale-105 transition-transform duration-300"
                  />
                </div>
              ) : (
                <div class="w-full aspect-[16/9] rounded-lg bg-[#222]"></div>
              )}
              <div class="mt-4 flex-1 flex flex-col">
                <div class="flex items-center gap-3 mb-3">
                  <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-[#FAFAFA]/10 text-[#FAFAFA]/70 border border-[#FAFAFA]/20">
                    {categoryLabels[post.data.category] || post.data.category}
                  </span>
                  <span class="text-xs text-[#FAFAFA]/40">{formatDate(post.data.publishDate)}</span>
                </div>
                <h2 class="text-lg font-semibold text-[#FAFAFA] group-hover:text-gray-300 transition-colors leading-snug mb-2">{post.data.title}</h2>
                <p class="text-sm text-[#FAFAFA]/60 leading-relaxed line-clamp-3 flex-1">{post.data.excerpt}</p>
                <p class="mt-4 text-xs font-semibold text-[#FAFAFA]/40 group-hover:text-[#FAFAFA]/70 transition-colors">Read article &rarr;</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-[#FAFAFA]">
      <div class="px-6 py-24 sm:px-6 sm:py-32 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-4xl font-serif font-bold tracking-tight text-gray-900 sm:text-5xl">Ready to start your renovation?</h2>
          <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-gray-600">Contact us for a free consultation and site visit. We will assess your space and provide a full itemised quotation with no obligation.</p>
          <div class="mt-10 flex flex-wrap justify-center gap-4">
            <a href="/contact/" class="rounded-md bg-[#333] px-5 py-3 text-lg font-semibold text-white shadow-sm hover:bg-gray-700 transition-colors">Get a free quote</a>
            <a
              href="https://wa.me/60128773999?text=Hi%2C%20I%27d%20like%20to%20enquire%20about%20a%20renovation%20project."
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-md bg-[#25D366] px-5 py-3 text-lg font-semibold text-white shadow-sm hover:bg-[#1da851] transition-colors"
              onclick="window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'whatsapp_click',location:'blog_hub_cta'});"
            >WhatsApp us</a>
          </div>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
