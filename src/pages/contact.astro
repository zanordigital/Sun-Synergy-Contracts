---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const FORMSPREE_ID = 'xlgzbllv';
const breadcrumbs = [{ name: 'Contact Us', url: '/contact' }];

const services = [
  'Home Renovation',
  'Interior Design',
  'Commercial Renovation',
  'Bespoke Carpentry & Joinery',
  'Premium Flooring',
  'Wet Works & Plumbing',
  'Aluminium & Glass Works',
  'Authority Submission & Permits',
  'Not sure yet',
];

const cities = [
  'Petaling Jaya',
  'Subang Jaya / USJ',
  'Puchong',
  'Kuala Lumpur',
  'Shah Alam',
  'Klang',
  'Cyberjaya / Putrajaya',
  'Kajang / Semenyih',
  'Other',
];
---

<BaseLayout
  title="Free Renovation Quote - Petaling Jaya & Klang Valley"
  description="Request a free site visit and itemised renovation quote from Sun Synergy Contracts, a CIDB G4 contractor in Petaling Jaya. Serving PJ, Subang and KL."
  ogImage="/img/projects/Za Altera/0.webp"
  schemaPage="contact"
  schemaBreadcrumbs={breadcrumbs}
>
  <main class="min-h-screen w-full">

    <!-- Hero -->
    <section class="relative isolate w-full min-h-[420px] flex items-end pb-16 pt-36">
      <div class="absolute inset-0 -z-10">
        <img
          src="/img/projects/Za Altera/0.webp"
          alt="Interior renovation project by Sun Synergy Contracts, Petaling Jaya"
          class="w-full h-full object-cover object-center"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/70 to-black/30"></div>
      </div>
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 w-full">
        <Breadcrumbs items={breadcrumbs} />
        <p class="text-xs text-[#FAFAFA]/60 uppercase mb-3">Sun Synergy Contracts</p>
        <h1 class="text-4xl md:text-5xl xl:text-6xl text-[#FAFAFA] font-serif font-bold max-w-3xl">Get a Free Renovation Consultation</h1>
        <p class="mt-4 text-lg text-[#FAFAFA]/80 max-w-2xl">Serving Petaling Jaya, Subang Jaya, Puchong, Kuala Lumpur and surrounding areas. Tell us about your project and we will arrange a free site visit and full itemised quotation.</p>
      </div>
    </section>

    <!-- Main contact section -->
    <section class="bg-black">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24 grid grid-cols-1 lg:grid-cols-2 gap-16">

        <!-- Left: info + trust signals -->
        <div>
          <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">How it works</p>
          <h2 class="text-2xl font-serif font-bold text-[#FAFAFA] mb-8">What happens after you reach out</h2>

          <ol class="space-y-6 mb-12">
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-[#FAFAFA]/10 border border-[#FAFAFA]/20 flex items-center justify-center text-sm font-bold text-[#FAFAFA]">1</span>
              <div>
                <p class="font-semibold text-[#FAFAFA]">We respond within 1 business day</p>
                <p class="text-sm text-[#FAFAFA]/60 mt-1">Our team will reach out to understand your project scope and schedule a convenient time for a site visit.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-[#FAFAFA]/10 border border-[#FAFAFA]/20 flex items-center justify-center text-sm font-bold text-[#FAFAFA]">2</span>
              <div>
                <p class="font-semibold text-[#FAFAFA]">Free site visit and consultation</p>
                <p class="text-sm text-[#FAFAFA]/60 mt-1">Our project manager visits your property to assess the space, understand your goals, and discuss your budget and timeline.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-[#FAFAFA]/10 border border-[#FAFAFA]/20 flex items-center justify-center text-sm font-bold text-[#FAFAFA]">3</span>
              <div>
                <p class="font-semibold text-[#FAFAFA]">Full itemised quotation, no obligation</p>
                <p class="text-sm text-[#FAFAFA]/60 mt-1">You receive a detailed written quote covering every line item - no hidden costs, no vague lump sums. You decide whether to proceed.</p>
              </div>
            </li>
          </ol>

          <div class="p-6 border border-[#333] rounded-lg mb-8">
            <h3 class="text-xs text-[#FAFAFA]/60 uppercase mb-4">Contact details</h3>
            <dl class="space-y-4 text-sm">
              <div class="flex gap-3">
                <svg class="h-5 w-5 text-[#FAFAFA]/40 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
                <div>
                  <dt class="text-[#FAFAFA]/40">Address</dt>
                  <dd class="text-[#FAFAFA]">17C, Jalan PJS 1/33<br />Taman Petaling Utama<br />46150 Petaling Jaya, Selangor<br />Malaysia</dd>
                </div>
              </div>
              <div class="flex gap-3">
                <svg class="h-5 w-5 text-[#FAFAFA]/40 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                </svg>
                <div>
                  <dt class="text-[#FAFAFA]/40">Phone</dt>
                  <dd class="text-[#FAFAFA]">
                    <a href="tel:+60128773999" class="hover:text-gray-300 transition-colors" onclick="window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'call_click',phone:'+60128773999',location:'contact_page'});">+60 12-877 3999</a>
                  </dd>
                </div>
              </div>
              <div class="flex gap-3">
                <svg class="h-5 w-5 text-[#FAFAFA]/40 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
                <div>
                  <dt class="text-[#FAFAFA]/40">Email</dt>
                  <dd class="text-[#FAFAFA]">
                    <a href="mailto:info@sunsynergycontracts.com.my" class="hover:text-gray-300 transition-colors" onclick="window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'email_click',email:'info@sunsynergycontracts.com.my',location:'contact_page'});">info@sunsynergycontracts.com.my</a>
                  </dd>
                </div>
              </div>
              <div class="flex gap-3">
                <svg class="h-5 w-5 text-[#FAFAFA]/40 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
                <div>
                  <dt class="text-[#FAFAFA]/40">Operating hours</dt>
                  <dd class="text-[#FAFAFA]">Mon - Fri: 8:30am - 5:30pm</dd>
                </div>
              </div>
            </dl>
          </div>

          <a
            href="https://wa.me/60128773999?text=Hi%2C%20I%27d%20like%20to%20enquire%20about%20a%20renovation%20project."
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-3 w-full rounded-md bg-[#25D366] px-5 py-3 text-sm font-bold text-white shadow-md hover:bg-[#1da851] transition-colors"
            onclick="window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'whatsapp_click',location:'contact_page'});"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
            </svg>
            WhatsApp us directly
          </a>
        </div>

        <!-- Right: form -->
        <div x-data="{ submitted: false, error: false }">
          <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">Request a quote</p>
          <h2 class="text-2xl font-serif font-bold text-[#FAFAFA] mb-8">Tell us about your project</h2>

          <form
            x-show="!submitted"
            action={`https://formspree.io/f/${FORMSPREE_ID}`}
            method="POST"
            @submit.prevent="
              fetch($el.action, { method: 'POST', body: new FormData($el), headers: { Accept: 'application/json' } })
                .then(r => { if (r.ok) { submitted = true; window.dataLayer=window.dataLayer||[]; window.dataLayer.push({event:'form_submit',form_name:'contact_form'}); } else { error = true; } })
                .catch(() => error = true)
            "
            class="space-y-5"
          >
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="first-name" class="block text-sm font-semibold text-[#FAFAFA] mb-2">First name *</label>
                <input type="text" name="first-name" id="first-name" autocomplete="given-name" required placeholder="Ahmad" class="block w-full rounded-md border-0 px-3.5 py-2.5 text-[#333] shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-[#333] text-sm" />
              </div>
              <div>
                <label for="last-name" class="block text-sm font-semibold text-[#FAFAFA] mb-2">Last name *</label>
                <input type="text" name="last-name" id="last-name" autocomplete="family-name" required placeholder="Rahman" class="block w-full rounded-md border-0 px-3.5 py-2.5 text-[#333] shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-[#333] text-sm" />
              </div>
            </div>

            <div>
              <label for="phone-number" class="block text-sm font-semibold text-[#FAFAFA] mb-2">Phone number *</label>
              <input type="tel" name="phone-number" id="phone-number" autocomplete="tel" required placeholder="+60 12-345 6789" class="block w-full rounded-md border-0 px-3.5 py-2.5 text-[#333] shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-[#333] text-sm" />
            </div>

            <div>
              <label for="email" class="block text-sm font-semibold text-[#FAFAFA] mb-2">Email address *</label>
              <input type="email" name="email" id="email" autocomplete="email" required placeholder="ahmad@example.com" class="block w-full rounded-md border-0 px-3.5 py-2.5 text-[#333] shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-[#333] text-sm" />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="service" class="block text-sm font-semibold text-[#FAFAFA] mb-2">Service required</label>
                <select name="service" id="service" class="block w-full rounded-md border-0 px-3.5 py-2.5 text-[#333] shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-[#333] text-sm">
                  <option value="">Select a service...</option>
                  {services.map((s) => <option value={s}>{s}</option>)}
                </select>
              </div>
              <div>
                <label for="city" class="block text-sm font-semibold text-[#FAFAFA] mb-2">Project location</label>
                <select name="city" id="city" class="block w-full rounded-md border-0 px-3.5 py-2.5 text-[#333] shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-[#333] text-sm">
                  <option value="">Select a city...</option>
                  {cities.map((c) => <option value={c}>{c}</option>)}
                </select>
              </div>
            </div>

            <div>
              <label for="message" class="block text-sm font-semibold text-[#FAFAFA] mb-2">Tell us about your project</label>
              <textarea name="message" id="message" rows="4" placeholder="E.g. Full renovation of a 2-storey terrace house in SS2. Includes kitchen, 3 bathrooms and living areas. Budget around RM 150,000." class="block w-full rounded-md border-0 px-3.5 py-2.5 text-[#333] shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-[#333] text-sm"></textarea>
            </div>

            <div class="pt-2">
              <button type="submit" class="w-full rounded-md bg-[#FAFAFA] px-5 py-3 text-sm font-bold text-[#333] shadow-md hover:bg-[#333] hover:text-[#FAFAFA] transition-all duration-150">
                Send my enquiry
              </button>
              <p class="text-xs text-[#FAFAFA]/40 mt-3 text-center">No obligation. We respond within 1 business day.</p>
            </div>

            <p x-cloak x-show="error" class="text-red-400 text-sm text-center">Something went wrong. Please try again or call us at <a href="tel:+60128773999" class="underline">+60 12-877 3999</a>.</p>
          </form>

          <div x-cloak x-show="submitted" class="py-16 text-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-14 w-14 text-green-400 mb-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            <p class="text-[#FAFAFA] text-2xl font-serif font-bold">Thank you!</p>
            <p class="text-[#FAFAFA]/60 mt-3 max-w-xs mx-auto">We've received your enquiry and will be in touch within 1 business day to arrange a free site visit.</p>
            <a href="/projects/" class="inline-block mt-6 text-sm text-[#FAFAFA]/60 hover:text-[#FAFAFA] underline transition-colors">Browse our completed projects while you wait</a>
          </div>
        </div>

      </div>
    </section>

    <!-- Trust bar -->
    <section class="bg-[#111] border-y border-[#333]">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-8 grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
        <div>
          <p class="text-2xl font-bold font-serif text-[#FAFAFA]">40+</p>
          <p class="text-sm text-[#FAFAFA]/60 mt-1">Projects completed across Klang Valley</p>
        </div>
        <div>
          <p class="text-2xl font-bold font-serif text-[#FAFAFA]">CIDB G4</p>
          <p class="text-sm text-[#FAFAFA]/60 mt-1">Certified renovation contractor</p>
        </div>
        <div>
          <p class="text-2xl font-bold font-serif text-[#FAFAFA]">Since 2016</p>
          <p class="text-sm text-[#FAFAFA]/60 mt-1">Serving homeowners and businesses</p>
        </div>
      </div>
    </section>

    <!-- Map -->
    <section>
      <iframe
        class="w-full h-[480px]"
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3984.0523508375154!2d101.64955277674518!3d3.0807010535658943!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31cc4a6bbc2a4387%3A0xefb4d5905eff9f83!2sSun%20Synergy%20Sdn.%20Bhd.!5e0!3m2!1sen!2smy!4v1705235964112!5m2!1sen!2smy"
        style="border: 0"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Sun Synergy Contracts office in Petaling Jaya, Selangor"
      ></iframe>
    </section>

  </main>
</BaseLayout>
