---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  return locations.map((location) => ({
    params: { slug: location.data.slug },
    props: { location: location.data },
  }));
}

const { location } = Astro.props;

const allProjects = await getCollection('projects');
const relatedProjects = location.relatedProjectSlugs
  ? allProjects.filter((p) => location.relatedProjectSlugs!.includes(p.id))
  : [];

const allServices = await getCollection('services');
const relatedServices = location.relatedServiceSlugs
  ? allServices.filter((s) => location.relatedServiceSlugs!.includes(s.data.slug))
  : [];
---

<BaseLayout
  title={location.metaTitle}
  description={location.metaDescription}
  schemaPage="area"
  schemaAreaName={location.name}
  schemaFaqs={location.faqs}
  schemaBreadcrumbs={[{ name: 'Areas', url: '/areas' }, { name: location.name, url: `/areas/${location.slug}` }]}
  whatsappMessage={`Hi, I'd like to enquire about renovation services in ${location.name}.`}
>
  <main class="min-h-screen w-full">

    <!-- Hero -->
    <section class="relative isolate w-full py-20 pt-40 overflow-hidden">
      {location.heroImage ? (
        <div class="absolute inset-0 -z-10">
          <img
            src={location.heroImage}
            alt={location.name}
            class="w-full h-full object-cover object-center"
            loading="eager"
          />
          <div class="absolute inset-0 bg-black/65"></div>
        </div>
      ) : (
        <div class="absolute inset-0 bg-black -z-10"></div>
      )}
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8">
        <p class="text-xs text-[#FAFAFA]/60 uppercase mb-3">Serving {location.name}</p>
        <h1 class="text-4xl md:text-5xl xl:text-6xl text-[#FAFAFA] font-serif font-bold max-w-3xl">{location.h1}</h1>
        <p class="mt-4 text-lg text-[#FAFAFA]/80 max-w-2xl">{location.heroSubhead}</p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="/contact"
            class="rounded-md bg-[#FAFAFA] px-5 py-3 text-sm font-bold text-[#333] shadow-md hover:bg-[#333] hover:text-[#FAFAFA] transition-all duration-150"
          >Get a free quote</a>
          <a
            href={`https://wa.me/60128773999?text=${encodeURIComponent(`Hi, I'd like to enquire about renovation services in ${location.name}.`)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-md bg-[#25D366] px-5 py-3 text-sm font-bold text-white shadow-md hover:bg-[#1da851] transition-all duration-150"
            onclick="window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'whatsapp_click',location:'area_hero'});"
          >WhatsApp us</a>
        </div>
      </div>
    </section>

    <!-- About this area -->
    <section class="bg-[#111]">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24 grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">Our local expertise</p>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#FAFAFA] mb-6">Why choose us in {location.name}</h2>
          <p class="text-[#FAFAFA]/80 leading-relaxed">{location.description}</p>
        </div>
        <div class="space-y-4">
          <div class="flex gap-4 items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#FAFAFA]/60 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
            </svg>
            <div>
              <h3 class="font-semibold text-[#FAFAFA]">CIDB G4 Licensed</h3>
              <p class="text-sm text-[#FAFAFA]/60">Licensed to carry out all building and renovation works in {location.name}.</p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#FAFAFA]/60 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
            <div>
              <h3 class="font-semibold text-[#FAFAFA]">Fast Site Visits</h3>
              <p class="text-sm text-[#FAFAFA]/60">Based in Petaling Jaya, we can visit your {location.name} property within 2-3 business days.</p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#FAFAFA]/60 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
            </svg>
            <div>
              <h3 class="font-semibold text-[#FAFAFA]">Transparent Pricing</h3>
              <p class="text-sm text-[#FAFAFA]/60">Fixed-price contracts with fully itemised quotations. No hidden costs.</p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#FAFAFA]/60 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
            </svg>
            <div>
              <h3 class="font-semibold text-[#FAFAFA]">Proven Track Record</h3>
              <p class="text-sm text-[#FAFAFA]/60">Over 40 projects delivered across Klang Valley since 2016.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Services in this area -->
    {relatedServices.length > 0 && (
      <section class="bg-black">
        <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24">
          <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">What we do in {location.name}</p>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#FAFAFA] mb-12">Services available in {location.name}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {relatedServices.map((service) => (
              <a href={`/services/${service.data.slug}`} class="group block p-6 border border-[#333] rounded-lg hover:border-[#FAFAFA]/40 transition-colors">
                <h3 class="text-lg font-semibold text-[#FAFAFA] mb-2 group-hover:text-gray-300 transition-colors">{service.data.title}</h3>
                <p class="text-sm text-[#FAFAFA]/60 line-clamp-2">{service.data.heroSubhead}</p>
                <p class="mt-4 text-xs text-[#FAFAFA]/40 group-hover:text-[#FAFAFA]/60 transition-colors">Learn more &rarr;</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Projects in this area -->
    {relatedProjects.length > 0 && (
      <section class="bg-[#111]">
        <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24">
          <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">Completed projects</p>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#FAFAFA] mb-12">Our work in {location.name}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {relatedProjects.map((project) => (
              <a href={`/projects/${project.id}`} class="group block">
                <div class="overflow-hidden rounded-lg bg-gray-900">
                  <img
                    loading="lazy"
                    src={`/img/projects/${project.data.folderName}/0.webp`}
                    alt={`${project.data.name} - renovation project in ${location.name}`}
                    class="w-full aspect-[4/3] object-cover object-center group-hover:scale-105 transition-transform duration-300"
                  />
                </div>
                <h3 class="mt-3 font-semibold text-[#FAFAFA] group-hover:text-gray-300 transition-colors">{project.data.name}</h3>
                <p class="text-sm text-[#FAFAFA]/60 mt-1">{project.data.duration}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- FAQs -->
    {location.faqs && location.faqs.length > 0 && (
      <section class="bg-black">
        <div class="mx-auto max-w-3xl px-4 sm:px-8 py-16 sm:py-24">
          <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">Common questions</p>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#FAFAFA] mb-12">FAQ - Renovation in {location.name}</h2>
          <dl class="space-y-8">
            {location.faqs.map((faq) => (
              <div>
                <dt class="text-lg font-semibold text-[#FAFAFA] mb-3">{faq.question}</dt>
                <dd class="text-[#FAFAFA]/70 leading-relaxed">{faq.answer}</dd>
              </div>
            ))}
          </dl>
        </div>
      </section>
    )}

    <!-- Map -->
    {location.mapEmbedSrc && (
      <section>
        <iframe
          class="w-full h-[400px]"
          src={location.mapEmbedSrc}
          style="border: 0"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`Map of ${location.name}`}
        ></iframe>
      </section>
    )}

    <!-- CTA -->
    <section class="bg-[#FAFAFA]">
      <div class="px-6 py-24 sm:px-6 sm:py-32 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-4xl font-serif font-bold tracking-tight text-gray-900 sm:text-5xl">Need a renovation in {location.name}?</h2>
          <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-gray-600">Contact us for a free consultation and site visit. We will assess your space and provide a full itemised quotation with no obligation.</p>
          <div class="mt-10 flex flex-wrap justify-center gap-4">
            <a href="/contact" class="rounded-md bg-[#333] px-5 py-3 text-lg font-semibold text-white shadow-sm hover:bg-gray-700 transition-colors">Get a free quote</a>
            <a
              href={`https://wa.me/60128773999?text=${encodeURIComponent(`Hi, I'd like to enquire about renovation services in ${location.name}.`)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-md bg-[#25D366] px-5 py-3 text-lg font-semibold text-white shadow-sm hover:bg-[#1da851] transition-colors"
              onclick="window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'whatsapp_click',location:'area_cta'});"
            >WhatsApp us</a>
          </div>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
