---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const locations = await getCollection('locations');

const areaOrder = ['petaling-jaya', 'subang-jaya-usj', 'puchong', 'kuala-lumpur'];
const sortedLocations = locations.sort(
  (a, b) => areaOrder.indexOf(a.data.slug) - areaOrder.indexOf(b.data.slug)
);
---

<BaseLayout
  title="Renovation Contractor Klang Valley | Sun Synergy Contracts"
  description="CIDB G4 renovation contractor serving Petaling Jaya, Subang Jaya, USJ, Puchong and Kuala Lumpur. Based in PJ with fast site visits across the Klang Valley."
  schemaPage="other"
  schemaBreadcrumbs={[{ name: 'Areas', url: '/areas' }]}
  whatsappMessage="Hi, I'd like to enquire about renovation services in the Klang Valley."
>
  <main class="min-h-screen w-full">

    <!-- Hero -->
    <section class="relative isolate w-full min-h-[500px] flex items-end pb-16 pt-36 overflow-hidden">
      <div class="absolute inset-0 -z-10">
        <img
          src="/img/projects/Skinny Dip/0.webp"
          alt="Renovation projects across Klang Valley by Sun Synergy Contracts"
          class="w-full h-full object-cover object-center"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/60 to-black/20"></div>
      </div>
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 w-full">
        <p class="text-xs text-[#FAFAFA]/60 uppercase mb-3">Where we work</p>
        <h1 class="text-4xl md:text-5xl xl:text-6xl text-[#FAFAFA] font-serif font-bold max-w-3xl">Renovation Contractor Serving the Klang Valley</h1>
        <p class="mt-4 text-lg text-[#FAFAFA]/80 max-w-2xl">Based in Petaling Jaya, we deliver renovation and interior design projects across PJ, Subang Jaya, USJ, Puchong, and Kuala Lumpur - with fast site visits and a consistent CIDB G4-certified team on every project.</p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="/contact"
            class="rounded-md bg-[#FAFAFA] px-5 py-3 text-sm font-bold text-[#333] shadow-md hover:bg-[#333] hover:text-[#FAFAFA] transition-all duration-150"
          >Get a free quote</a>
          <a
            href="https://wa.me/60128773999?text=Hi%2C%20I%27d%20like%20to%20enquire%20about%20renovation%20services%20in%20the%20Klang%20Valley."
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-md bg-[#25D366] px-5 py-3 text-sm font-bold text-white shadow-md hover:bg-[#1da851] transition-all duration-150"
            onclick="window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'whatsapp_click',location:'areas_hub_hero'});"
          >WhatsApp us</a>
        </div>
      </div>
    </section>

    <!-- Area cards -->
    <section class="bg-black">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24">
        <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">Our primary service areas</p>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#FAFAFA] mb-12 max-w-2xl">Four areas, one consistent team</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {sortedLocations.map((location) => (
            <a href={`/areas/${location.data.slug}`} class="group relative block overflow-hidden rounded-xl bg-gray-900">
              {location.data.heroImage && (
                <img
                  loading="lazy"
                  src={location.data.heroImage}
                  alt={`Renovation projects in ${location.data.name}`}
                  class="w-full aspect-[16/9] object-cover object-center group-hover:scale-105 transition-transform duration-500"
                />
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <h3 class="text-xl font-bold text-[#FAFAFA] mb-1">{location.data.name}</h3>
                <p class="text-sm text-[#FAFAFA]/70 line-clamp-2">{location.data.heroSubhead}</p>
                <p class="mt-3 text-xs font-semibold text-[#FAFAFA]/50 group-hover:text-[#FAFAFA]/80 transition-colors">View projects & services &rarr;</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Why local matters -->
    <section class="bg-[#111]">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">Why our location matters</p>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#FAFAFA] mb-6">Petaling Jaya HQ means faster response</h2>
          <p class="text-[#FAFAFA]/80 leading-relaxed mb-6">Being headquartered in PJ means we can reach any address in Petaling Jaya, Subang Jaya, USJ, and Puchong within a day. Kuala Lumpur projects are equally accessible. No waiting weeks for a site visit - we typically arrange one within 2 to 3 business days of your enquiry.</p>
          <p class="text-[#FAFAFA]/80 leading-relaxed">We also understand local property types - from PJ link houses and USJ condos to KL shophouses and Puchong landed terrace homes. That local knowledge translates into more accurate quotes and fewer surprises on site.</p>
        </div>
        <div class="space-y-4">
          {[
            { area: 'Petaling Jaya', note: 'HQ location - fastest response' },
            { area: 'Subang Jaya & USJ', note: '15 min from HQ' },
            { area: 'Puchong', note: '20 min from HQ' },
            { area: 'Kuala Lumpur', note: 'Regular project base' },
            { area: 'Shah Alam, Klang, Cyberjaya, Kajang', note: 'Extended Klang Valley' },
          ].map(({ area, note }) => (
            <div class="flex items-center justify-between py-3 border-b border-[#333]">
              <span class="font-semibold text-[#FAFAFA]">{area}</span>
              <span class="text-sm text-[#FAFAFA]/50">{note}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-[#FAFAFA]">
      <div class="px-6 py-24 sm:px-6 sm:py-32 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-4xl font-serif font-bold tracking-tight text-gray-900 sm:text-5xl">Ready to start your renovation?</h2>
          <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-gray-600">Contact us for a free consultation and site visit. We will assess your space and provide a full itemised quotation with no obligation.</p>
          <div class="mt-10 flex flex-wrap justify-center gap-4">
            <a href="/contact" class="rounded-md bg-[#333] px-5 py-3 text-lg font-semibold text-white shadow-sm hover:bg-gray-700 transition-colors">Get a free quote</a>
            <a
              href="https://wa.me/60128773999?text=Hi%2C%20I%27d%20like%20to%20enquire%20about%20renovation%20services%20in%20the%20Klang%20Valley."
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-md bg-[#25D366] px-5 py-3 text-lg font-semibold text-white shadow-sm hover:bg-[#1da851] transition-colors"
              onclick="window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'whatsapp_click',location:'areas_hub_cta'});"
            >WhatsApp us</a>
          </div>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
