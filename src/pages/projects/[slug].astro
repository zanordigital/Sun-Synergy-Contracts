---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project: project.data },
  }));
}

const { project } = Astro.props;
const { slug } = Astro.params;

const serviceLabels: Record<string, string> = {
  'home-renovation': 'Home Renovation',
  'interior-design': 'Interior Design',
  'commercial-renovation': 'Commercial Renovation',
  'kitchen-cabinetry': 'Carpentry & Joinery',
  'premium-flooring': 'Premium Flooring',
  'wet-works-plumbing': 'Wet Works & Plumbing',
  'aluminium-glass': 'Aluminium & Glass',
  'authority-submission': 'Authority Submission',
};

const propertyLabels: Record<string, string> = {
  'terrace': 'Terrace House',
  'condo': 'Condominium',
  'semi-d': 'Semi-Detached',
  'bungalow': 'Bungalow',
  'shoplot': 'Shop / Retail',
  'office': 'Office',
  'government': 'Government Facility',
  'other': 'Property',
};

const imageCount = project.images;
const images = Array.from({ length: imageCount }, (_, i) => i);

const allProjects = await getCollection('projects');
const relatedProjects = allProjects
  .filter((p) => p.id !== slug && p.data.services?.some((s) => project.services?.includes(s)))
  .slice(0, 3);

// Meta description: use the authored project.description (a complete sentence),
// trimmed to a word boundary at <=155 chars so it never cuts mid-word, then
// stripped of any trailing punctuation or dangling connector words so it does
// not end on "and", "for a", etc.
function metaDescription(text: string, max = 155): string {
  if (text.length <= max) return text;
  let cut = text.slice(0, max);
  const lastSpace = cut.lastIndexOf(' ');
  cut = cut.slice(0, lastSpace > 0 ? lastSpace : max);
  let prev: string;
  do {
    prev = cut;
    cut = cut
      .replace(/[\s,;:.-]+$/, '')
      .replace(/\s+(and|or|a|an|the|for|to|with|of|in|on|at|by)$/i, '');
  } while (cut !== prev);
  return cut;
}
const metaDesc = metaDescription(project.description);
---

<BaseLayout
  title={project.metaTitle ?? `${project.name} - Renovation Project`}
  description={metaDesc}
  schemaPage="project"
  schemaBreadcrumbs={[{ name: 'Projects', url: '/projects' }, { name: project.name, url: `/projects/${slug}` }]}
>
  <main class="min-h-screen w-full">

    <!-- Hero image -->
    <section class="relative w-full min-h-[500px] flex items-end pb-12 pt-24">
      <div class="absolute inset-0 -z-10">
        <img
          src={`/img/projects/${project.folderName}/0.jpg`}
          alt={`${project.name} renovation by Sun Synergy Contracts`}
          class="w-full h-full object-cover object-center"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/50 to-transparent"></div>
      </div>
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 w-full">
        <div class="flex flex-wrap gap-2 mb-4">
          {project.services && project.services.map((s) => (
            <a href={`/services/${s}`} class="text-xs font-semibold px-3 py-1 rounded-full bg-[#FAFAFA]/10 text-[#FAFAFA]/80 border border-[#FAFAFA]/20 hover:bg-[#FAFAFA]/20 transition-colors">
              {serviceLabels[s] || s}
            </a>
          ))}
          {project.propertyType && (
            <span class="text-xs font-semibold px-3 py-1 rounded-full bg-[#FAFAFA]/10 text-[#FAFAFA]/80 border border-[#FAFAFA]/20">
              {propertyLabels[project.propertyType] || project.propertyType}
            </span>
          )}
        </div>
        <h1 class="text-4xl md:text-5xl font-serif font-bold text-[#FAFAFA] max-w-3xl">{project.name}</h1>
        <div class="flex flex-wrap gap-4 mt-4 text-sm text-[#FAFAFA]/70">
          {project.city && <span>{project.city}{project.neighbourhood ? `, ${project.neighbourhood}` : ''}</span>}
          <span>Duration: {project.duration}</span>
          {project.year && <span>Completed: {project.year}</span>}
        </div>
      </div>
    </section>

    <!-- Overview -->
    <section class="bg-black">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24 grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">Project overview</p>
          <p class="text-[#FAFAFA]/80 leading-relaxed text-lg">{project.body || project.description}</p>
          {project.scopeBullets && project.scopeBullets.length > 0 && (
            <div class="mt-8">
              <h2 class="text-lg font-semibold text-[#FAFAFA] mb-4">Scope of works</h2>
              <ul class="space-y-2">
                {project.scopeBullets.map((bullet) => (
                  <li class="flex gap-3 text-[#FAFAFA]/70">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#FAFAFA]/40 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                    <span class="text-sm">{bullet}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
        <div class="space-y-6">
          <div class="p-6 border border-[#333] rounded-lg">
            <h3 class="text-xs text-[#FAFAFA]/60 uppercase mb-4">Project details</h3>
            <dl class="space-y-3 text-sm">
              {project.city && (
                <div>
                  <dt class="text-[#FAFAFA]/40">Location</dt>
                  <dd class="text-[#FAFAFA] font-medium">{project.city}{project.neighbourhood ? `, ${project.neighbourhood}` : ''}</dd>
                </div>
              )}
              <div>
                <dt class="text-[#FAFAFA]/40">Duration</dt>
                <dd class="text-[#FAFAFA] font-medium">{project.duration}</dd>
              </div>
              {project.year && (
                <div>
                  <dt class="text-[#FAFAFA]/40">Year</dt>
                  <dd class="text-[#FAFAFA] font-medium">{project.year}</dd>
                </div>
              )}
              {project.propertyType && (
                <div>
                  <dt class="text-[#FAFAFA]/40">Property type</dt>
                  <dd class="text-[#FAFAFA] font-medium">{propertyLabels[project.propertyType] || project.propertyType}</dd>
                </div>
              )}
            </dl>
          </div>
          {project.testimonial && (
            <blockquote class="p-6 border border-[#333] rounded-lg">
              <p class="text-[#FAFAFA]/80 italic text-sm leading-relaxed">"{project.testimonial.quote}"</p>
              <footer class="mt-3 text-xs text-[#FAFAFA]/40">- {project.testimonial.clientInitial}, {project.city || 'Klang Valley'}</footer>
            </blockquote>
          )}
          <a
            href="/contact"
            class="block w-full text-center rounded-md bg-[#FAFAFA] px-5 py-3 text-sm font-bold text-[#333] shadow-md hover:bg-[#333] hover:text-[#FAFAFA] transition-all duration-150"
          >Start a similar project</a>
        </div>
      </div>
    </section>

    <!-- Photo gallery with lightbox -->
    {imageCount > 1 && (
      <section class="bg-[#111]">
        <div
          class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24"
          x-data={`{ lightboxOpen: false, activeIndex: 0, imageCount: ${imageCount}, folderName: '${project.folderName.replace(/'/g, "\\'")}' }`}
          @keydown.escape.window="lightboxOpen = false"
          @keydown.arrow-right.window="if (lightboxOpen) activeIndex = (activeIndex + 1) % imageCount"
          @keydown.arrow-left.window="if (lightboxOpen) activeIndex = (activeIndex - 1 + imageCount) % imageCount"
        >
          <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">Project photos</p>
          <h2 class="text-3xl font-serif font-bold text-[#FAFAFA] mb-8">Gallery</h2>

          <!-- Grid -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {images.slice(1).map((i) => (
              <button
                type="button"
                class="overflow-hidden rounded-lg bg-gray-900 cursor-zoom-in w-full"
                x-on:click={`activeIndex = ${i}; lightboxOpen = true`}
              >
                <img
                  loading="lazy"
                  src={`/img/projects/${project.folderName}/${i}.jpg`}
                  alt={`${project.name} - photo ${i + 1} by Sun Synergy Contracts`}
                  class="w-full aspect-[4/3] object-cover object-center hover:scale-105 transition-transform duration-300"
                />
              </button>
            ))}
          </div>

          <!-- Lightbox overlay -->
          <div
            x-cloak
            x-show="lightboxOpen"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            class="fixed inset-0 z-[100] flex items-center justify-center bg-black/90"
            @click.self="lightboxOpen = false"
          >
            <!-- Close -->
            <button
              type="button"
              @click="lightboxOpen = false"
              class="absolute top-4 right-4 text-white/70 hover:text-white p-2"
              aria-label="Close lightbox"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
              </svg>
            </button>

            <!-- Prev -->
            <button
              type="button"
              @click="activeIndex = (activeIndex - 1 + imageCount) % imageCount"
              class="absolute left-4 text-white/70 hover:text-white p-2"
              aria-label="Previous photo"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
              </svg>
            </button>

            <!-- Main image -->
            <img
              :src="'/img/projects/' + folderName + '/' + activeIndex + '.jpg'"
              :alt="'Photo ' + (activeIndex + 1) + ' of ${project.name}'"
              class="max-h-[90vh] max-w-[90vw] object-contain rounded-lg shadow-2xl"
            />

            <!-- Next -->
            <button
              type="button"
              @click="activeIndex = (activeIndex + 1) % imageCount"
              class="absolute right-4 text-white/70 hover:text-white p-2"
              aria-label="Next photo"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
              </svg>
            </button>

            <!-- Counter -->
            <p class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/60 text-sm" x-text="(activeIndex + 1) + ' / ' + imageCount"></p>
          </div>
        </div>
      </section>
    )}

    <!-- Related projects -->
    {relatedProjects.length > 0 && (
      <section class="bg-black">
        <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24">
          <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">More work</p>
          <h2 class="text-3xl font-serif font-bold text-[#FAFAFA] mb-10">Related projects</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {relatedProjects.map((p) => (
              <a href={`/projects/${p.id}`} class="group block">
                <div class="overflow-hidden rounded-lg bg-gray-900">
                  <img
                    loading="lazy"
                    src={`/img/projects/${p.data.folderName}/0.jpg`}
                    alt={`${p.data.name} renovation by Sun Synergy Contracts`}
                    class="w-full aspect-[4/3] object-cover object-center group-hover:scale-105 transition-transform duration-300"
                  />
                </div>
                <h3 class="mt-3 font-semibold text-[#FAFAFA] group-hover:text-gray-300 transition-colors">{p.data.name}</h3>
                <p class="text-sm text-[#FAFAFA]/60 mt-1">{p.data.city}{p.data.neighbourhood ? `, ${p.data.neighbourhood}` : ''}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="bg-[#FAFAFA]">
      <div class="px-6 py-24 sm:px-6 sm:py-32 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-4xl font-serif font-bold tracking-tight text-gray-900 sm:text-5xl">Like what you see?</h2>
          <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-gray-600">Contact us to discuss your project. We will assess your space and provide a full itemised quotation with no obligation.</p>
          <div class="mt-10 flex flex-wrap justify-center gap-4">
            <a href="/contact" class="rounded-md bg-[#333] px-5 py-3 text-lg font-semibold text-white shadow-sm hover:bg-gray-700 transition-colors">Speak with us</a>
            <a href="/projects" class="rounded-md border border-gray-300 px-5 py-3 text-lg font-semibold text-gray-700 hover:bg-gray-50 transition-colors">See all projects</a>
          </div>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
