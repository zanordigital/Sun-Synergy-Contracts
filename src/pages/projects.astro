---
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryModal from '../components/GalleryModal.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
---

<BaseLayout
  title="Our Projects - Sun Synergy Contracts"
  description="Browse our portfolio of commercial and residential interior design and renovation projects across Klang Valley."
>
  <main class="min-h-screen w-full space-y-5">

    <section class="relative isolate mx-auto w-full py-12 grid place-items-center mt-36">
      <div class="space-y-2">
        <p class="text-xs text-[#FAFAFA] mx-auto text-center uppercase">OUR PROJECTS</p>
        <h1 class="text-4xl md:text-5xl xl:text-6xl text-[#FAFAFA] font-serif mx-auto text-center font-bold">Together we create your happy place.</h1>
      </div>
    </section>

    <section class="bg-black">
      <div class="mx-auto max-w-screen-xl overflow-hidden px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
        <div class="grid gap-x-6 gap-y-10 grid-cols-[repeat(auto-fill,minmax(333px,1fr))] lg:gap-x-8">
          {allProjects.map((project) => (
            <a
              @click={`idGallery = '${project.id}'; isGalleryModalOpen = true`}
              class="cursor-pointer group text-sm"
            >
              <div class="aspect-h-1 aspect-w-[1.3] w-full overflow-hidden rounded-lg bg-gray-100 group-hover:opacity-75 transition-all duration-150 ease-linear">
                <img
                  loading="lazy"
                  src={`/img/projects/${project.data.folderName}/0.jpg`}
                  alt={`${project.data.name} project by Sun Synergy Contracts`}
                  class="h-full w-full object-cover object-center"
                />
              </div>
              <h2 class="mt-4 font-medium text-[#FAFAFA] text-lg">{project.data.name}</h2>
              <div class="flex flex-row items-center gap-2 mt-1">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-gray-400">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm.75-13a.75.75 0 0 0-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 0 0 0-1.5h-3.25V5Z" clip-rule="evenodd" />
                </svg>
                <p class="font-medium text-gray-400">{project.data.duration}</p>
              </div>
              <p class="italic text-gray-300 line-clamp-4 hyphens-auto mt-2">{project.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-[#FAFAFA]">
      <div class="px-6 py-24 sm:px-6 sm:py-32 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-4xl font-serif font-bold tracking-tight text-gray-900 sm:text-5xl">Let us create your happy place.<br />Together.</h2>
          <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-gray-600">We provide highly creative and modern interior design solutions for commercial and residential spaces with a classic touch to meet their demands and expectations.</p>
          <div class="mt-10">
            <a href="/contact" class="rounded-md bg-[#333] px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-gray-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-800">Speak with us</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <GalleryModal />
</BaseLayout>
