---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');

const serviceLabels: Record<string, string> = {
  'home-renovation': 'Home Renovation',
  'interior-design': 'Interior Design',
  'commercial-renovation': 'Commercial Renovation',
  'kitchen-cabinetry': 'Carpentry & Joinery',
  'premium-flooring': 'Premium Flooring',
  'wet-works-plumbing': 'Wet Works & Plumbing',
  'aluminium-glass': 'Aluminium & Glass',
  'authority-submission': 'Authority Submission',
};

const propertyLabels: Record<string, string> = {
  'terrace': 'Terrace House',
  'condo': 'Condominium',
  'semi-d': 'Semi-Detached',
  'bungalow': 'Bungalow',
  'shoplot': 'Shop / Retail',
  'office': 'Office',
  'government': 'Government Facility',
  'other': 'Property',
};

const sortedProjects = allProjects.sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));
---

<BaseLayout
  title="Renovation & Interior Design Projects | Sun Synergy Contracts"
  description="Browse 40+ completed renovation and interior design projects across the Klang Valley. Home renovation, commercial fit-out, swimming pools, kitchen cabinetry and more. CIDB G4 certified."
  schemaPage="other"
  schemaBreadcrumbs={[{ name: 'Projects', url: '/projects' }]}
>
  <main class="min-h-screen w-full">

    <!-- Hero -->
    <section class="relative isolate w-full min-h-[500px] flex items-end pb-16 pt-36">
      <div class="absolute inset-0 -z-10">
        <img
          src="/img/projects/Mercedes Benz/0.jpg"
          alt="Renovation projects by Sun Synergy Contracts across the Klang Valley"
          class="w-full h-full object-cover object-center"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/60 to-black/20"></div>
      </div>
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 w-full">
        <p class="text-xs text-[#FAFAFA]/60 uppercase mb-3">Our portfolio</p>
        <h1 class="text-4xl md:text-5xl xl:text-6xl text-[#FAFAFA] font-serif font-bold max-w-3xl">Renovation Projects Across the Klang Valley</h1>
        <p class="mt-4 text-lg text-[#FAFAFA]/80 max-w-2xl">From bungalow renovations in Petaling Jaya to commercial fit-outs in Kuala Lumpur, browse our completed projects and see the standard we deliver. Every project was managed end-to-end by Sun Synergy Contracts under a single fixed-price contract.</p>
      </div>
    </section>

    <!-- Stats bar -->
    <section class="bg-[#111] border-y border-[#333]">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-6 flex flex-wrap gap-8 items-center">
        <div class="text-[#FAFAFA]">
          <span class="text-2xl font-bold font-serif">{allProjects.length}</span>
          <span class="text-sm text-[#FAFAFA]/60 ml-2">projects shown</span>
        </div>
        <div class="text-[#FAFAFA]">
          <span class="text-2xl font-bold font-serif">6</span>
          <span class="text-sm text-[#FAFAFA]/60 ml-2">service lines</span>
        </div>
        <div class="text-[#FAFAFA]">
          <span class="text-2xl font-bold font-serif">4+</span>
          <span class="text-sm text-[#FAFAFA]/60 ml-2">cities across Klang Valley</span>
        </div>
        <div class="text-[#FAFAFA]">
          <span class="text-2xl font-bold font-serif">CIDB G4</span>
          <span class="text-sm text-[#FAFAFA]/60 ml-2">certified contractor</span>
        </div>
      </div>
    </section>

    <!-- Projects grid -->
    <section class="bg-black">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {sortedProjects.map((project) => (
            <a href={`/projects/${project.id}`} class="group block">
              <div class="overflow-hidden rounded-lg bg-gray-900">
                <img
                  loading="lazy"
                  src={`/img/projects/${project.data.folderName}/0.jpg`}
                  alt={`${project.data.name} renovation by Sun Synergy Contracts`}
                  class="w-full aspect-[4/3] object-cover object-center group-hover:scale-105 transition-transform duration-300"
                />
              </div>
              <div class="mt-4">
                {project.data.services && project.data.services.length > 0 && (
                  <div class="flex flex-wrap gap-1 mb-2">
                    {project.data.services.slice(0, 2).map((s) => (
                      <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-[#FAFAFA]/10 text-[#FAFAFA]/70">
                        {serviceLabels[s] || s}
                      </span>
                    ))}
                  </div>
                )}
                <h2 class="font-semibold text-[#FAFAFA] text-lg group-hover:text-gray-300 transition-colors">{project.data.name}</h2>
                <div class="flex flex-wrap gap-3 mt-1 text-sm text-[#FAFAFA]/60">
                  {project.data.city && <span>{project.data.city}</span>}
                  <span>{project.data.duration}</span>
                  {project.data.propertyType && <span>{propertyLabels[project.data.propertyType] || project.data.propertyType}</span>}
                </div>
                <p class="mt-2 text-sm text-[#FAFAFA]/50 line-clamp-2">{project.data.description}</p>
                <p class="mt-3 text-xs font-semibold text-[#FAFAFA]/50 group-hover:text-[#FAFAFA] transition-colors">View project &rarr;</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-[#FAFAFA]">
      <div class="px-6 py-24 sm:px-6 sm:py-32 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-4xl font-serif font-bold tracking-tight text-gray-900 sm:text-5xl">Like what you see?</h2>
          <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-gray-600">Contact us to discuss your project. We will assess your space and provide a fully itemised quotation with no obligation.</p>
          <div class="mt-10 flex flex-wrap justify-center gap-4">
            <a href="/contact" class="rounded-md bg-[#333] px-5 py-3 text-lg font-semibold text-white shadow-sm hover:bg-gray-700 transition-colors">Get a free quote</a>
            <a
              href="https://wa.me/60128773999?text=Hi%2C%20I%27d%20like%20to%20enquire%20about%20a%20renovation%20project."
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-md bg-[#25D366] px-5 py-3 text-lg font-semibold text-white shadow-sm hover:bg-[#1da851] transition-colors"
              onclick="window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'whatsapp_click',location:'projects_cta'});"
            >WhatsApp us</a>
          </div>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
