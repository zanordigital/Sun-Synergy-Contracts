---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((service) => ({
    params: { slug: service.data.slug },
    props: { service: service.data },
  }));
}

const { service } = Astro.props;

const allProjects = await getCollection('projects');
const relatedProjects = service.relatedProjectSlugs
  ? allProjects.filter((p) => service.relatedProjectSlugs!.includes(p.id))
  : [];

const serviceLabels: Record<string, string> = {
  'home-renovation': 'Home Renovation',
  'interior-design': 'Interior Design',
  'commercial-renovation': 'Commercial Renovation',
  'kitchen-cabinetry': 'Carpentry & Joinery',
  'premium-flooring': 'Premium Flooring',
  'wet-works-plumbing': 'Wet Works & Plumbing',
  'aluminium-glass': 'Aluminium & Glass',
  'authority-submission': 'Authority Submission',
};
---

<BaseLayout
  title={service.metaTitle}
  description={service.metaDescription}
  schemaPage="service"
  schemaServiceName={service.title}
  schemaServiceDescription={service.description}
  schemaFaqs={service.faqs}
  schemaBreadcrumbs={[{ name: 'Services', url: '/services' }, { name: service.title, url: `/services/${service.slug}` }]}
  whatsappMessage={`Hi, I'd like a quote for ${service.title} in Klang Valley.`}
>
  <main class="min-h-screen w-full">

    <!-- Hero -->
    <section class="relative isolate w-full min-h-[420px] flex items-end pb-16 pt-36">
      {service.heroImage && (
        <div class="absolute inset-0 -z-10">
          <img
            src={service.heroImage}
            alt={service.h1}
            class="w-full h-full object-cover object-center"
            loading="eager"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black via-black/60 to-black/20"></div>
        </div>
      )}
      {!service.heroImage && (
        <div class="absolute inset-0 -z-10 bg-black"></div>
      )}
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 w-full">
        <p class="text-xs text-[#FAFAFA]/60 uppercase mb-3">Sun Synergy Contracts</p>
        <h1 class="text-4xl md:text-5xl xl:text-6xl text-[#FAFAFA] font-serif font-bold max-w-3xl">{service.h1}</h1>
        <p class="mt-4 text-lg text-[#FAFAFA]/80 max-w-2xl">{service.heroSubhead}</p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="/contact"
            class="rounded-md bg-[#FAFAFA] px-5 py-3 text-sm font-bold text-[#333] shadow-md hover:bg-[#333] hover:text-[#FAFAFA] transition-all duration-150"
          >Get a free quote</a>
          <a
            href={`https://wa.me/60128773999?text=${encodeURIComponent(`Hi, I'd like a quote for ${service.title} in Klang Valley.`)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-md bg-[#25D366] px-5 py-3 text-sm font-bold text-white shadow-md hover:bg-[#1da851] transition-all duration-150"
            onclick="window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'whatsapp_click',location:'service_hero'});"
          >WhatsApp us</a>
        </div>
      </div>
    </section>

    <!-- Trust bar -->
    <section class="bg-[#111] border-y border-[#333]">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-6 flex flex-wrap gap-6 items-center justify-between">
        <div class="flex items-center gap-3 text-[#FAFAFA]">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#FAFAFA]/60 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
          </svg>
          <span class="text-sm font-semibold">CIDB G4 Certified</span>
        </div>
        <div class="flex items-center gap-3 text-[#FAFAFA]">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#FAFAFA]/60 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
          </svg>
          <span class="text-sm font-semibold">Petaling Jaya Based</span>
        </div>
        <div class="flex items-center gap-3 text-[#FAFAFA]">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#FAFAFA]/60 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
          </svg>
          <span class="text-sm font-semibold">Fixed Timeline & Price</span>
        </div>
        <div class="flex items-center gap-3 text-[#FAFAFA]">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#FAFAFA]/60 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
          </svg>
          <span class="text-sm font-semibold">Serving Klang Valley</span>
        </div>
      </div>
    </section>

    <!-- Problem / Why us -->
    <section class="bg-black">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24 grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div>
          <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">The common problem</p>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#FAFAFA] mb-8">Why most {service.title.toLowerCase()} projects go wrong</h2>
          <ul class="space-y-4">
            {service.problems.map((problem) => (
              <li class="flex gap-3 text-[#FAFAFA]/80">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
                <span>{problem}</span>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">Our approach</p>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#FAFAFA] mb-8">How Sun Synergy Contracts is different</h2>
          <p class="text-[#FAFAFA]/80 leading-relaxed">{service.description}</p>
          {(service.priceFromMYR || service.priceCeilingMYR) && (
            <div class="mt-8 p-6 border border-[#333] rounded-lg">
              <p class="text-xs text-[#FAFAFA]/60 uppercase mb-2">Typical Investment</p>
              {service.priceFromMYR && service.priceCeilingMYR && (
                <p class="text-2xl font-bold text-[#FAFAFA]">RM {service.priceFromMYR.toLocaleString()} to RM {service.priceCeilingMYR.toLocaleString()}</p>
              )}
              {service.priceFromMYR && !service.priceCeilingMYR && (
                <p class="text-2xl font-bold text-[#FAFAFA]">From RM {service.priceFromMYR.toLocaleString()}</p>
              )}
              <p class="text-sm text-[#FAFAFA]/60 mt-2">Exact pricing depends on scope and specification. We provide a full itemised quotation after a free site visit.</p>
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="bg-[#FAFAFA]">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24">
        <p class="text-xs text-gray-500 uppercase mb-4">How we work</p>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-gray-900 mb-12">Our {service.title} process</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {service.processSteps.map((step, i) => (
            <div class="relative">
              <div class="text-5xl font-black text-gray-100 leading-none mb-4 select-none">{String(i + 1).padStart(2, '0')}</div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{step.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{step.detail}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Related projects -->
    {relatedProjects.length > 0 && (
      <section class="bg-black">
        <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24">
          <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">Proof of work</p>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#FAFAFA] mb-12">Our {service.title.toLowerCase()} projects</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {relatedProjects.map((project) => (
              <a href={`/projects/${project.id}`} class="group block">
                <div class="overflow-hidden rounded-lg bg-gray-900">
                  <img
                    loading="lazy"
                    src={`/img/projects/${project.data.folderName}/0.jpg`}
                    alt={`${project.data.name} - ${service.title} by Sun Synergy Contracts`}
                    class="w-full aspect-[4/3] object-cover object-center group-hover:scale-105 transition-transform duration-300"
                  />
                </div>
                <h3 class="mt-3 font-semibold text-[#FAFAFA] group-hover:text-gray-300 transition-colors">{project.data.name}</h3>
                {project.data.city && (
                  <p class="text-sm text-[#FAFAFA]/60 mt-1">{project.data.city} &bull; {project.data.duration}</p>
                )}
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- FAQs -->
    {service.faqs && service.faqs.length > 0 && (
      <section class="bg-[#111]">
        <div class="mx-auto max-w-3xl px-4 sm:px-8 py-16 sm:py-24">
          <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">Common questions</p>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#FAFAFA] mb-12">{service.title} FAQ</h2>
          <dl class="divide-y divide-[#333]" x-data="{ open: null }">
            {service.faqs.map((faq, i) => (
              <div class="py-5">
                <dt>
                  <button
                    type="button"
                    class="flex w-full items-center justify-between gap-4 text-left"
                    x-on:click={`open = open === ${i} ? null : ${i}`}
                    :aria-expanded={`open === ${i}`}
                  >
                    <span class="text-base font-semibold text-[#FAFAFA]">{faq.question}</span>
                    <span
                      class="flex-shrink-0 text-[#FAFAFA]/40"
                      :class={`open === ${i} ? 'rotate-45' : ''`}
                      style="transition: transform 0.2s ease;"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                      </svg>
                    </span>
                  </button>
                </dt>
                <dd
                  x-show={`open === ${i}`}
                  x-transition:enter="transition ease-out duration-200"
                  x-transition:enter-start="opacity-0 -translate-y-1"
                  x-transition:enter-end="opacity-100 translate-y-0"
                  x-transition:leave="transition ease-in duration-150"
                  x-transition:leave-start="opacity-100 translate-y-0"
                  x-transition:leave-end="opacity-0 -translate-y-1"
                  class="mt-4 pr-10"
                >
                  <p class="text-[#FAFAFA]/70 leading-relaxed text-sm">{faq.answer}</p>
                </dd>
              </div>
            ))}
          </dl>
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="bg-[#FAFAFA]">
      <div class="px-6 py-24 sm:px-6 sm:py-32 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-4xl font-serif font-bold tracking-tight text-gray-900 sm:text-5xl">Ready to get started?</h2>
          <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-gray-600">Contact us for a free consultation and site visit. We will assess your space, understand your goals, and provide a full itemised quotation with no obligation.</p>
          <div class="mt-10 flex flex-wrap justify-center gap-4">
            <a href="/contact" class="rounded-md bg-[#333] px-5 py-3 text-lg font-semibold text-white shadow-sm hover:bg-gray-700 transition-colors">Get a free quote</a>
            <a
              href={`https://wa.me/60128773999?text=${encodeURIComponent(`Hi, I'd like a quote for ${service.title} in Klang Valley.`)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-md bg-[#25D366] px-5 py-3 text-lg font-semibold text-white shadow-sm hover:bg-[#1da851] transition-colors"
              onclick="window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'whatsapp_click',location:'service_cta'});"
            >WhatsApp us</a>
          </div>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
