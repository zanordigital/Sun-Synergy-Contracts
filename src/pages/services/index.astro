---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const services = await getCollection('services');

const serviceIcons: Record<string, string> = {
  'home-renovation': 'M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25',
  'interior-design': 'M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42',
  'commercial-renovation': 'M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21',
  'kitchen-cabinetry': 'M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0H3',
  'premium-flooring': 'M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z',
  'wet-works-plumbing': 'M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 1-6.23-.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5',
  'aluminium-glass': 'M9 4.5v15m6-15v15m-10.875 0h15.75c.621 0 1.125-.504 1.125-1.125V5.625c0-.621-.504-1.125-1.125-1.125H4.125C3.504 4.5 3 5.004 3 5.625v12.75c0 .621.504 1.125 1.125 1.125Z',
  'authority-submission': 'M11.35 3.836c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m8.9-4.414c.376.023.75.05 1.124.08 1.131.094 1.976 1.057 1.976 2.192V16.5A2.25 2.25 0 0 1 18 18.75h-2.25m-7.5-10.5H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V18.75m-7.5-10.5h6.375c.621 0 1.125.504 1.125 1.125v9.375m-8.25-3 1.5 1.5 3-3.75',
  'office-renovation': 'M2.25 21V6.75A2.25 2.25 0 0 1 4.5 4.5h15a2.25 2.25 0 0 1 2.25 2.25V21M2.25 21h19.5M8.25 21V10.5a.75.75 0 0 1 .75-.75h5.25a.75.75 0 0 1 .75.75V21M3.75 10.5h16.5',
};

const serviceOrder = ['home-renovation', 'interior-design', 'commercial-renovation', 'office-renovation', 'kitchen-cabinetry', 'premium-flooring', 'wet-works-plumbing', 'aluminium-glass', 'authority-submission'];
const sortedServices = services.sort((a, b) => serviceOrder.indexOf(a.data.slug) - serviceOrder.indexOf(b.data.slug));
---

<BaseLayout
  title="Renovation & Interior Design Services Malaysia"
  description="Full-service renovation contractor in Klang Valley: home and commercial renovation, interior design, carpentry, flooring and more. CIDB G4 certified."
  schemaPage="other"
  schemaBreadcrumbs={[{ name: 'Services', url: '/services' }]}
  whatsappMessage="Hi, I'd like to enquire about your renovation services."
>
  <main class="min-h-screen w-full">

    <!-- Hero -->
    <section class="relative isolate w-full min-h-[500px] flex items-end pb-16 pt-36">
      <div class="absolute inset-0 -z-10">
        <img
          src="/img/projects/Hillcrest/0.webp"
          alt="Sun Synergy Contracts renovation and interior design services"
          class="w-full h-full object-cover object-center"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/60 to-black/20"></div>
      </div>
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 w-full">
        <p class="text-xs text-[#FAFAFA]/60 uppercase mb-3">Our services</p>
        <h1 class="text-4xl md:text-5xl xl:text-6xl text-[#FAFAFA] font-serif font-bold max-w-3xl">Renovation & Interior Design Services in Malaysia</h1>
        <p class="mt-4 text-lg text-[#FAFAFA]/80 max-w-2xl">From home renovation to commercial fit-out, bespoke carpentry to authority submissions - we handle every aspect of your project under one CIDB G4 certified roof. Headquartered in Petaling Jaya, serving the entire Klang Valley and beyond across Malaysia.</p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="/contact/"
            class="rounded-md bg-[#FAFAFA] px-5 py-3 text-sm font-bold text-[#333] shadow-md hover:bg-[#333] hover:text-[#FAFAFA] transition-all duration-150"
          >Get a free quote</a>
          <a
            href="https://wa.me/60128773999?text=Hi%2C%20I%27d%20like%20to%20enquire%20about%20your%20renovation%20services."
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-md bg-[#25D366] px-5 py-3 text-sm font-bold text-white shadow-md hover:bg-[#1da851] transition-all duration-150"
            onclick="window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'whatsapp_click',location:'services_hub_hero'});"
          >WhatsApp us</a>
        </div>
      </div>
    </section>

    <!-- Trust bar -->
    <section class="bg-[#111] border-y border-[#333]">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-6 flex flex-wrap gap-6 items-center justify-between">
        <div class="flex items-center gap-3 text-[#FAFAFA]">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#FAFAFA]/60 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
          </svg>
          <span class="text-sm font-semibold">CIDB G4 Certified</span>
        </div>
        <div class="flex items-center gap-3 text-[#FAFAFA]">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#FAFAFA]/60 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
          </svg>
          <span class="text-sm font-semibold">PJ HQ, Nationwide Reach</span>
        </div>
        <div class="flex items-center gap-3 text-[#FAFAFA]">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#FAFAFA]/60 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
          </svg>
          <span class="text-sm font-semibold">Fixed Timeline & Price</span>
        </div>
        <div class="flex items-center gap-3 text-[#FAFAFA]">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#FAFAFA]/60 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" />
          </svg>
          <span class="text-sm font-semibold">One Contractor, All Trades</span>
        </div>
      </div>
    </section>

    <!-- Professional memberships strip -->
    <section class="bg-[#0a0a0a] border-b border-[#222]">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-5 flex flex-wrap items-center justify-center gap-x-10 gap-y-4">
        <span class="text-xs text-[#FAFAFA]/40 uppercase tracking-wider font-semibold flex-shrink-0">Member of</span>
        <img src="/img/associations/miid-Web-Logo.png" width="400" height="80" alt="MIID - Malaysian Institute of Interior Designers" class="h-8 object-contain opacity-60 hover:opacity-100 transition-opacity" loading="lazy" />
        <img src="/img/associations/Cidb-Malaysia-Logo.png" width="1875" height="519" alt="CIDB Malaysia" class="h-8 object-contain opacity-60 hover:opacity-100 transition-opacity" loading="lazy" />
        <img src="/img/associations/MBAM_logo.png" width="262" height="263" alt="Master Builders Association Malaysia" class="h-8 object-contain opacity-60 hover:opacity-100 transition-opacity" loading="lazy" />
        <img src="/img/associations/MIIP Logo.PNG" width="493" height="235" alt="MIIP - Malaysian Interior Industry Partners" class="h-8 object-contain opacity-60 hover:opacity-100 transition-opacity" loading="lazy" />
      </div>
    </section>

    <!-- Services grid -->
    <section class="bg-black">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24">
        <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">What we do</p>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#FAFAFA] mb-12 max-w-2xl">Nine service lines, one accountable contractor</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {sortedServices.map((service) => (
            <a href={`/services/${service.data.slug}/`} class="group block p-8 border border-[#333] rounded-lg hover:border-[#FAFAFA]/40 hover:bg-[#111] transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-[#FAFAFA]/60 mb-6 group-hover:text-[#FAFAFA] transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d={serviceIcons[service.data.slug] || 'M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z'} />
              </svg>
              <h3 class="text-xl font-bold text-[#FAFAFA] mb-3 group-hover:text-gray-300 transition-colors">{service.data.title}</h3>
              <p class="text-sm text-[#FAFAFA]/70 leading-relaxed mb-4">{service.data.heroSubhead}</p>
              {service.data.priceFromMYR && (
                <p class="text-xs font-semibold text-[#FAFAFA]/50 mb-4">From RM {service.data.priceFromMYR.toLocaleString()}</p>
              )}
              <p class="text-xs font-semibold text-[#FAFAFA]/60 group-hover:text-[#FAFAFA] transition-colors">Learn more &rarr;</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Why choose us -->
    <section class="bg-[#FAFAFA]">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24">
        <p class="text-xs text-gray-500 uppercase mb-4">Why Sun Synergy Contracts</p>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-gray-900 mb-12 max-w-2xl">One team, one contract, one point of accountability</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <div class="text-5xl font-black text-gray-100 leading-none mb-4 select-none">01</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">CIDB G4 licensed</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Licensed by the Construction Industry Development Board to carry out building, renovation, and fit-out works across Malaysia. All workers registered, all projects insured.</p>
          </div>
          <div>
            <div class="text-5xl font-black text-gray-100 leading-none mb-4 select-none">02</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Fully integrated trades</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Structural, M&E, tiling, carpentry, painting, aluminium, and wet works - all coordinated by us. No chasing subcontractors. No blame-shifting between trades when something goes wrong.</p>
          </div>
          <div>
            <div class="text-5xl font-black text-gray-100 leading-none mb-4 select-none">03</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Fixed price, fixed timeline</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Every project starts with a fully itemised quotation and a written contract specifying timeline and milestone payments. No mid-project surprises.</p>
          </div>
          <div>
            <div class="text-5xl font-black text-gray-100 leading-none mb-4 select-none">04</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Headed by a named designer</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Catherine Ng, our Design Director, oversees every project. You will know exactly who is responsible for your design and your build, from day one to handover.</p>
          </div>
          <div>
            <div class="text-5xl font-black text-gray-100 leading-none mb-4 select-none">05</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Klang Valley HQ, nationwide reach</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Based in Petaling Jaya for fast site visits across PJ, Subang, Puchong, KL and the wider Klang Valley. We also take on commercial and high-value residential projects across the rest of Malaysia.</p>
          </div>
          <div>
            <div class="text-5xl font-black text-gray-100 leading-none mb-4 select-none">06</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Track record since 2016</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Over 40 projects delivered including landmark commercial fit-outs (KLIA Control Tower, Mercedes-Benz Cycle & Carriage) and high-end residential renovations across the Klang Valley.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="bg-black">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24">
        <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">How we work</p>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#FAFAFA] mb-12 max-w-2xl">A predictable, transparent process from first call to handover</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-8">
          <div>
            <div class="text-5xl font-black text-[#FAFAFA]/10 leading-none mb-4 select-none">01</div>
            <h3 class="text-base font-bold text-[#FAFAFA] mb-2">Free consultation</h3>
            <p class="text-[#FAFAFA]/60 text-sm leading-relaxed">Site visit and goal-setting conversation, no obligation.</p>
          </div>
          <div>
            <div class="text-5xl font-black text-[#FAFAFA]/10 leading-none mb-4 select-none">02</div>
            <h3 class="text-base font-bold text-[#FAFAFA] mb-2">Design & quote</h3>
            <p class="text-[#FAFAFA]/60 text-sm leading-relaxed">Detailed concept and fully itemised quotation with no hidden costs.</p>
          </div>
          <div>
            <div class="text-5xl font-black text-[#FAFAFA]/10 leading-none mb-4 select-none">03</div>
            <h3 class="text-base font-bold text-[#FAFAFA] mb-2">Contract & schedule</h3>
            <p class="text-[#FAFAFA]/60 text-sm leading-relaxed">Written contract with fixed timeline and milestone payments.</p>
          </div>
          <div>
            <div class="text-5xl font-black text-[#FAFAFA]/10 leading-none mb-4 select-none">04</div>
            <h3 class="text-base font-bold text-[#FAFAFA] mb-2">Construction</h3>
            <p class="text-[#FAFAFA]/60 text-sm leading-relaxed">All trades sequenced and supervised by a dedicated site manager.</p>
          </div>
          <div>
            <div class="text-5xl font-black text-[#FAFAFA]/10 leading-none mb-4 select-none">05</div>
            <h3 class="text-base font-bold text-[#FAFAFA] mb-2">Handover</h3>
            <p class="text-[#FAFAFA]/60 text-sm leading-relaxed">Joint walkthrough, defect rectification, then final payment.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Areas served -->
    <section class="bg-[#111]">
      <div class="mx-auto max-w-screen-xl px-4 sm:px-8 py-16 sm:py-24">
        <p class="text-xs text-[#FAFAFA]/60 uppercase mb-4">Where we work</p>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#FAFAFA] mb-6 max-w-2xl">Klang Valley primary, Malaysia nationwide</h2>
        <p class="text-[#FAFAFA]/70 leading-relaxed max-w-2xl mb-12">Our four primary service areas are Petaling Jaya, Subang Jaya & USJ, Puchong, and Kuala Lumpur. We also accept projects across the wider Klang Valley (Shah Alam, Klang, Cyberjaya, Kajang) and undertake high-value residential and commercial work throughout Malaysia.</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <a href="/areas/petaling-jaya/" class="block p-6 border border-[#333] rounded-lg hover:border-[#FAFAFA]/40 transition-colors">
            <h3 class="text-lg font-bold text-[#FAFAFA]">Petaling Jaya</h3>
            <p class="text-xs text-[#FAFAFA]/50 mt-2">Primary HQ</p>
          </a>
          <a href="/areas/subang-jaya-usj/" class="block p-6 border border-[#333] rounded-lg hover:border-[#FAFAFA]/40 transition-colors">
            <h3 class="text-lg font-bold text-[#FAFAFA]">Subang Jaya & USJ</h3>
            <p class="text-xs text-[#FAFAFA]/50 mt-2">Primary area</p>
          </a>
          <a href="/areas/puchong/" class="block p-6 border border-[#333] rounded-lg hover:border-[#FAFAFA]/40 transition-colors">
            <h3 class="text-lg font-bold text-[#FAFAFA]">Puchong</h3>
            <p class="text-xs text-[#FAFAFA]/50 mt-2">Primary area</p>
          </a>
          <a href="/areas/kuala-lumpur/" class="block p-6 border border-[#333] rounded-lg hover:border-[#FAFAFA]/40 transition-colors">
            <h3 class="text-lg font-bold text-[#FAFAFA]">Kuala Lumpur</h3>
            <p class="text-xs text-[#FAFAFA]/50 mt-2">Primary area</p>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-[#FAFAFA]">
      <div class="px-6 py-24 sm:px-6 sm:py-32 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-4xl font-serif font-bold tracking-tight text-gray-900 sm:text-5xl">Ready to start your project?</h2>
          <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-gray-600">Tell us about your space and what you want to achieve. We will arrange a free site visit and provide a fully itemised quotation with no obligation.</p>
          <div class="mt-10 flex flex-wrap justify-center gap-4">
            <a href="/contact/" class="rounded-md bg-[#333] px-5 py-3 text-lg font-semibold text-white shadow-sm hover:bg-gray-700 transition-colors">Get a free quote</a>
            <a
              href="https://wa.me/60128773999?text=Hi%2C%20I%27d%20like%20to%20enquire%20about%20your%20renovation%20services."
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-md bg-[#25D366] px-5 py-3 text-lg font-semibold text-white shadow-sm hover:bg-[#1da851] transition-colors"
              onclick="window.dataLayer=window.dataLayer||[];window.dataLayer.push({event:'whatsapp_click',location:'services_hub_cta'});"
            >WhatsApp us</a>
          </div>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
